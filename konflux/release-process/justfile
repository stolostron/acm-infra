# Debug flag (set to "true" to enable debug output)
debug := "false"

# Workspace directory for saving release files (can be overridden)
workspace := "."

# Query bugs from Jira for a specific application and version
# bundle: "true" (bundle-bugs only), "false" (exclude bundle-bugs, default)
query-bugs app version bundle="false":
    #!/usr/bin/env bash
    set -euo pipefail

    # Build bundle filter clause
    if [ "{{bundle}}" = "true" ]; then
        bundle_clause=" and labels = \"bundle-bug\""
    else
        bundle_clause=" and (labels is EMPTY OR labels != \"bundle-bug\")"
    fi

    # Build the JQL query for bugs
    jql_query="project = \"Red Hat Advanced Cluster Management\" and fixVersion = \"{{app}} {{version}}\" and resolution not in (\"Can't Do\", \"Cannot Reproduce\", Duplicate, MirrorOrphan, \"Not a Bug\", Obsolete, Unresolved, \"Won't Do\") and status not in (open, backlog) and issuetype NOT IN (Weakness, Vulnerability) and (labels in (doc-required, doc-require, doc-req) OR \"SFDC_Cases_Counter\" > 0)${bundle_clause}"

    # Query Jira for bugs
    jira_output=$(jira issue list -q "$jql_query" --raw 2>&1) || {
        # If query failed, check if it's just "no results" or a real error
        if echo "$jira_output" | grep -q "No result found"; then
            jira_output="[]"
        else
            echo "$jira_output" >&2
            exit 1
        fi
    }

    # Extract and format bug keys
    echo "$jira_output" | jq -r 'map({id: .key, source: "issues.redhat.com"}) | sort_by(.id)' | yq -p=json

# Query CVEs from Jira for a specific application and version
query-cves app version:
    #!/usr/bin/env bash
    set -euo pipefail

    # Create suffix (e.g., "2.13.5" -> "213")
    suffix=$(echo "{{version}}" | cut -d. -f1,2 | tr -d '.')

    # Fetch component registry to temp file
    registry_file=$(mktemp)
    trap "rm -f $registry_file" EXIT
    gh api repos/stolostron/acm-config/contents/product/component-registry.yaml?ref=main --jq '.content' | base64 -d > "$registry_file"

    # Build the JQL query
    jql_query="project = \"Red Hat Advanced Cluster Management\" and issuetype in (Weakness, Vulnerability) and fixVersion = \"{{app}} {{version}}\" and resolution not in (\"Can't Do\", \"Cannot Reproduce\", Duplicate, MirrorOrphan, \"Not a Bug\", Obsolete, Unresolved, \"Won't Do\") and status not in (open, backlog)"

    # Query Jira for CVEs
    jira_output=$(jira issue list -q "$jql_query" --raw 2>&1) || {
        # If query failed, check if it's just "no results" or a real error
        if echo "$jira_output" | grep -q "No result found"; then
            jira_output="[]"
        else
            echo "$jira_output" >&2
            exit 1
        fi
    }

    # Debug: Show CVE -> Jira issue mapping
    if [[ "{{debug}}" == "true" ]]; then
        echo "[query-cves] CVE to Jira Issue mapping:" >&2
        echo "$jira_output" | jq -r '.[] |
            (.fields.labels[] | select(test("^CVE-[0-9]+-[0-9]+$"))) as $cve |
            (.fields.labels[] | select(startswith("pscomponent:"))) as $ps |
            "\u001b]8;;https://redhat.atlassian.net/browse/\(.key)\u001b\\\(.key)\u001b]8;;\u001b\\: \($cve) (\($ps))"
        ' | sort -k2 >&2 || true
        echo "" >&2
    fi

    # Load component registry
    registry=$(yq -o=json "$registry_file")

    # Output YAML
    output=$(echo "$jira_output" | jq -s --argjson registry "$registry" --arg suffix "$suffix" '
        .[0] as $jira |
        ($registry.components | map(select(.prodseccomponent != null)) | map({(.prodseccomponent): .konflux_component}) | add) as $lookup |
        $jira | map({
            key: (.fields.labels[] | select(test("^CVE-[0-9]+-[0-9]+$"))),
            prodseccomponent: (.fields.labels[] | select(startswith("pscomponent:")))
        }) |
        map(
            .prodseccomponent as $ps |
            .component = (
                $lookup[$ps] //
                (
                    ("⚠️  Missing mapping for: " + $ps + " (CVE: " + .key + ")") | debug |
                    "FIXME:" + $ps
                )
            ) + "-" + $suffix
        ) |
        map({key, component}) |
        unique
    ' | yq -p=json)

    echo "$output"

    # Exit with error if any FIXME entries exist
    if echo "$output" | grep -q "FIXME:"; then
        exit 1
    fi

# Private: validate common inputs
_validate type app rc:
    #!/usr/bin/env bash
    set -euo pipefail
    if [[ "{{type}}" != "stage" && "{{type}}" != "prod" ]]; then
        echo "Error: type must be 'stage' or 'prod'" >&2
        exit 1
    fi
    if [[ "{{app}}" != "acm" && "{{app}}" != "mce" ]]; then
        echo "Error: app must be 'acm' or 'mce'" >&2
        exit 1
    fi
    if [[ "{{type}}" == "stage" && -z "{{rc}}" ]]; then
        echo "Error: rc parameter is required for stage releases" >&2
        exit 1
    fi

# Private: show YAML and confirm
_show_and_confirm yaml skip_confirm="false" dry_run="true":
    #!/usr/bin/env bash
    set -euo pipefail

    # Show the YAML to the user
    echo "{{yaml}}"

    # Confirm unless skip_confirm is true
    if [ "{{skip_confirm}}" != "true" ]; then
        echo "" >&2
        if [ "{{dry_run}}" = "true" ]; then
            echo "Press Enter to continue (DRY-RUN), or Ctrl+C to cancel..." >&2
        else
            echo "Press Enter to continue (LIVE), or Ctrl+C to cancel..." >&2
        fi
        read -r
    fi

# Private: apply YAML to cluster with confirmation
_apply yaml skip_confirm="false" dry_run="true":
    #!/usr/bin/env bash
    set -euo pipefail

    # Show and confirm
    just _show_and_confirm "{{yaml}}" {{skip_confirm}} {{dry_run}}

    # Apply to cluster
    if [ "{{dry_run}}" = "true" ]; then
        echo "{{yaml}}" | oc apply --dry-run=server -f -
    else
        echo "{{yaml}}" | oc apply -f -
    fi

# Private: build base release YAML from template
_build_base app snapshot release_name release_plan release_type:
    #!/usr/bin/env bash
    set -euo pipefail

    if [[ "{{debug}}" == "true" ]]; then
        echo "[_build_base] Starting..." >&2
        echo "[_build_base] app={{app}}, snapshot={{snapshot}}" >&2
        echo "[_build_base] release_name={{release_name}}, release_plan={{release_plan}}, release_type={{release_type}}" >&2
    fi

    namespace="crt-redhat-acm-tenant"
    [[ "{{debug}}" == "true" ]] && echo "[_build_base] namespace=$namespace" >&2 || true

    author=$(git config user.email 2>/dev/null | cut -d'@' -f1)
    if [ -z "$author" ]; then
        echo "❌ Failed to get git user.email. Please configure git:" >&2
        echo "   git config user.name \"Your Name\"" >&2
        echo "   git config user.email \"your.email@example.com\"" >&2
        exit 1
    fi
    [[ "{{debug}}" == "true" ]] && echo "[_build_base] author=$author" >&2 || true

    [[ "{{debug}}" == "true" ]] && echo "[_build_base] Running yq eval..." >&2 || true

    yq eval ".metadata.name = \"{{release_name}}\" |
        .metadata.namespace = \"$namespace\" |
        .metadata.labels[\"release.appstudio.openshift.io/author\"] = \"$author\" |
        .spec.snapshot = \"{{snapshot}}\" |
        .spec.releasePlan = \"{{release_plan}}\" |
        .spec.data.releaseNotes.type = \"{{release_type}}\"" \
        templates/release.yaml || {
        echo "[_build_base] yq eval failed!" >&2
        exit 1
    }

    [[ "{{debug}}" == "true" ]] && echo "[_build_base] Complete" >&2 || true

# Generate a payload YAML (outputs to stdout)
generate-payload type app version snapshot rc="": (_validate type app rc)
    #!/usr/bin/env bash
    set -euo pipefail

    # Parse version
    major=$(echo "{{version}}" | cut -d. -f1)
    minor=$(echo "{{version}}" | cut -d. -f2)
    patch=$(echo "{{version}}" | cut -d. -f3)
    short_version="${major}${minor}"

    # Build metadata
    if [ "{{type}}" = "stage" ]; then
        release_name="stage-publish-{{app}}-${short_version}-z${patch}-rc{{rc}}"
        release_plan="stage-publish-{{app}}-${short_version}"
    else
        release_name="prod-publish-{{app}}-${short_version}-z${patch}"
        release_plan="prod-publish-{{app}}-${short_version}"
    fi

    # Y stream releases (X.Y.0) don't include bugs/CVEs
    if [ "$patch" = "0" ]; then
        [[ "{{debug}}" == "true" ]] && echo "[generate-payload] Y stream release detected, skipping bug/CVE queries..." >&2
        release_type="RHEA"
        bug_count=0
        cve_count=0
    else
        [[ "{{debug}}" == "true" ]] && echo "[generate-payload] Querying Jira for bugs and CVEs..." >&2

        # Query bugs and CVEs
        bugs_file=$(mktemp)
        cves_file=$(mktemp)
        trap "rm -f $bugs_file $cves_file" EXIT

        just debug={{debug}} query-bugs {{app}} {{version}} false > "$bugs_file"
        just debug={{debug}} query-cves {{app}} {{version}} > "$cves_file"

        # Determine release type based on CVEs
        cve_count=$(yq 'length' "$cves_file")
        bug_count=$(yq 'length' "$bugs_file")

        if [ "$cve_count" -gt 0 ]; then
            release_type="RHSA"
        elif [ "$bug_count" -gt 0 ]; then
            release_type="RHBA"
        else
            release_type="RHEA"
        fi
    fi

    if [[ "{{debug}}" == "true" ]]; then
        echo "[generate-payload] Generating payload YAML..." >&2
        echo "[generate-payload]   Release type: $release_type" >&2
        echo "[generate-payload]   Bugs: $bug_count" >&2
        echo "[generate-payload]   CVEs: $cve_count" >&2
    fi

    # Build base YAML
    output=$(just debug={{debug}} _build_base {{app}} {{snapshot}} "$release_name" "$release_plan" "$release_type")

    # Add references for ACM RHSA
    if [[ "{{app}}" == "acm" && "$release_type" == "RHSA" ]]; then
        output=$(echo "$output" | yq eval '.spec.data.releaseNotes.references = ["https://access.redhat.com/security/updates/classification/#important"]')
    fi

    # Add bugs if any (only for Z stream releases)
    if [ "$patch" != "0" ] && [ "$bug_count" -gt 0 ]; then
        output=$(echo "$output" | yq eval ".spec.data.releaseNotes.issues.fixed = load(\"$bugs_file\")")
    fi

    # Add CVEs if any (only for Z stream releases)
    if [ "$patch" != "0" ] && [ "$cve_count" -gt 0 ]; then
        output=$(echo "$output" | yq eval ".spec.data.releaseNotes.cves = load(\"$cves_file\")")
    fi

    echo "$output"

# Apply a payload release to the cluster
apply-payload type app version snapshot rc="" skip_confirm="false" dry_run="true": (_validate type app rc)
    #!/usr/bin/env bash
    set -euo pipefail

    # Generate the payload
    payload=$(just debug={{debug}} generate-payload {{type}} {{app}} {{version}} {{snapshot}} {{rc}})

    # Apply using helper
    just _apply "$payload" {{skip_confirm}} {{dry_run}}

# Generate a catalog YAML (outputs to stdout)
generate-catalog type app version snapshot rc="": (_validate type app rc)
    #!/usr/bin/env bash
    set -euo pipefail

    # Parse version
    major=$(echo "{{version}}" | cut -d. -f1)
    minor=$(echo "{{version}}" | cut -d. -f2)
    patch=$(echo "{{version}}" | cut -d. -f3)
    short_version="${major}${minor}"

    # Build metadata
    if [ "{{type}}" = "stage" ]; then
        release_name="stage-publish-catalog-{{app}}-${short_version}-z${patch}-rc{{rc}}"
        release_plan="{{app}}-release-plan-stage"
    else
        release_name="prod-publish-catalog-{{app}}-${short_version}-z${patch}"
        release_plan="{{app}}-release-plan-prod"
    fi

    [[ "{{debug}}" == "true" ]] && echo "[generate-catalog] Generating catalog YAML..." >&2

    # Build base YAML (catalog is always RHEA)
    output=$(just debug={{debug}} _build_base {{app}} {{snapshot}} "$release_name" "$release_plan" "RHEA")

    # Add references for ACM
    if [[ "{{app}}" == "acm" ]]; then
        output=$(echo "$output" | yq eval '.spec.data.releaseNotes.references = ["https://access.redhat.com/security/updates/classification/#important"]')
    fi

    echo "$output"

# Apply a catalog release to the cluster
apply-catalog type app version snapshot rc="" skip_confirm="false" dry_run="true": (_validate type app rc)
    #!/usr/bin/env bash
    set -euo pipefail

    # Generate the catalog
    catalog=$(just debug={{debug}} generate-catalog {{type}} {{app}} {{version}} {{snapshot}} {{rc}})

    # Apply using helper
    just _apply "$catalog" {{skip_confirm}} {{dry_run}}

# Generate a bundle YAML (outputs to stdout)
generate-bundle type app version snapshot rc="": (_validate type app rc)
    #!/usr/bin/env bash
    set -euo pipefail

    # Parse version
    major=$(echo "{{version}}" | cut -d. -f1)
    minor=$(echo "{{version}}" | cut -d. -f2)
    patch=$(echo "{{version}}" | cut -d. -f3)
    short_version="${major}${minor}"

    # Build metadata
    if [ "{{type}}" = "stage" ]; then
        release_name="stage-publish-bundle-{{app}}-${short_version}-z${patch}-rc{{rc}}"
        release_plan="stage-publish-bundle-{{app}}-${short_version}"
    else
        release_name="prod-publish-bundle-{{app}}-${short_version}-z${patch}"
        release_plan="prod-publish-bundle-{{app}}-${short_version}"
    fi

    [[ "{{debug}}" == "true" ]] && echo "[generate-bundle] Generating bundle YAML..." >&2

    # Build base YAML (bundle is always RHBA)
    output=$(just debug={{debug}} _build_base {{app}} {{snapshot}} "$release_name" "$release_plan" "RHBA")

    # Y stream releases (X.Y.0) don't include bugs
    if [ "$patch" != "0" ]; then
        # Query bundle bugs
        bugs_file=$(mktemp)
        trap "rm -f $bugs_file" EXIT

        just debug={{debug}} query-bugs {{app}} {{version}} true > "$bugs_file"

        # Add bugs if any
        bug_count=$(yq 'length' "$bugs_file")
        if [ "$bug_count" -gt 0 ]; then
            output=$(echo "$output" | yq eval ".spec.data.releaseNotes.issues.fixed = load(\"$bugs_file\")")
        fi
    fi

    echo "$output"

# Apply a bundle release to the cluster
apply-bundle type app version snapshot rc="" skip_confirm="false" dry_run="true": (_validate type app rc)
    #!/usr/bin/env bash
    set -euo pipefail

    # Generate the bundle
    bundle=$(just debug={{debug}} generate-bundle {{type}} {{app}} {{version}} {{snapshot}} {{rc}})

    # Apply using helper
    just _apply "$bundle" {{skip_confirm}} {{dry_run}}

# Clone release management repo and create a branch
clone-release-mgmt branch_name cert_file="":
    #!/usr/bin/env bash
    set -euo pipefail

    repo_dir="acm-release-management"
    upstream="acm/acm-release-management"
    gitlab_host="gitlab.cee.redhat.com"

    # Set SSL cert file if provided
    if [ -n "{{cert_file}}" ]; then
        export SSL_CERT_FILE="{{cert_file}}"
    fi

    # Clone if not exists
    if [ ! -d "$repo_dir" ]; then
        git clone git@$gitlab_host:$upstream.git
    fi

    cd "$repo_dir"

    # Fetch latest and create branch from main
    git fetch origin
    git checkout -b {{branch_name}} origin/main

    echo "✅ Branch {{branch_name}} created from origin/main"

# Release: generate YAML, save to disk, and apply to cluster
release target type app version snapshot rc="" skip_confirm="false" dry_run="true": (_validate type app rc)
    #!/usr/bin/env bash
    set -euo pipefail

    # Validate target
    if [[ "{{target}}" != "payload" && "{{target}}" != "bundle" && "{{target}}" != "catalog" ]]; then
        echo "Error: target must be 'payload', 'bundle', or 'catalog'" >&2
        exit 1
    fi

    # Parse version
    major=$(echo "{{version}}" | cut -d. -f1)
    minor=$(echo "{{version}}" | cut -d. -f2)
    patch=$(echo "{{version}}" | cut -d. -f3)
    short_version="${major}${minor}"

    # Build directory path
    app_upper=$(echo "{{app}}" | tr '[:lower:]' '[:upper:]')
    release_dir="{{workspace}}/${app_upper}/${app_upper}-{{version}}"

    if [ "{{type}}" = "stage" ]; then
        release_dir="${release_dir}/rc{{rc}}"
        suffix="stage-z${patch}-rc{{rc}}"
    else
        suffix="prod-z${patch}"
    fi

    # Create directory if it doesn't exist
    mkdir -p "$release_dir"
    echo "📁 Saving release files to: $release_dir" >&2

    # Fetch and save snapshot from cluster first (fail if not found)
    echo "  Fetching snapshot from cluster..." >&2
    snapshot_file="${release_dir}/snapshot-{{app}}-${short_version}-{{target}}-${suffix}.yaml"
    oc get snapshot {{snapshot}} -n crt-redhat-acm-tenant -o yaml > "$snapshot_file" || {
        echo "❌ Failed to fetch snapshot {{snapshot}} from cluster" >&2
        exit 1
    }
    echo "  ✓ Saved: $(basename "$snapshot_file")" >&2

    # Generate the YAML
    echo "  Generating {{target}}..." >&2
    target_yaml=$(just debug={{debug}} generate-{{target}} {{type}} {{app}} {{version}} {{snapshot}} {{rc}})

    # Show and confirm before saving
    echo "" >&2
    just _show_and_confirm "$target_yaml" {{skip_confirm}} {{dry_run}}

    # Save to disk after confirmation
    target_file="${release_dir}/{{app}}-${short_version}-{{target}}-${suffix}.yaml"
    echo "$target_yaml" > "$target_file"
    echo "" >&2
    echo "  ✓ Saved: $(basename "$target_file")" >&2
    echo "✅ Release {{target}} saved successfully!" >&2
    echo "   Directory: $release_dir" >&2

    # Apply to cluster
    echo "" >&2
    if [ "{{dry_run}}" = "true" ]; then
        echo "$target_yaml" | oc apply --dry-run=server -f -
    else
        echo "$target_yaml" | oc apply -f -
    fi
