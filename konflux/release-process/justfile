# Unified release wrapper: delegates to stage-release or prod-release based on type
[arg("snapshot", long="snapshot")]
[arg("rc", long="rc")]
[arg("skip_confirm", long="skip_confirm")]
[arg("dry_run", long="dry_run")]
[arg("ocp_versions", long="ocp_versions")]
release target type app version snapshot="" rc="" skip_confirm="false" dry_run="true" ocp_versions="": (_validate_app app)
    #!/usr/bin/env bash
    set -euo pipefail

    # Validate type
    if [[ "{{type}}" != "stage" && "{{type}}" != "prod" ]]; then
        echo "Error: type must be 'stage' or 'prod'" >&2
        exit 1
    fi

    # Validate snapshot for stage releases
    if [[ "{{type}}" == "stage" && -z "{{snapshot}}" ]]; then
        echo "Error: --snapshot parameter is required for stage releases" >&2
        exit 1
    fi

    # Build rc argument if provided
    rc_arg=""
    if [ -n "{{rc}}" ]; then
        rc_arg="--rc {{rc}}"
    fi

    # Delegate to appropriate recipe
    if [ "{{type}}" = "stage" ]; then
        just stage-release {{target}} {{app}} {{version}} {{snapshot}} $rc_arg --skip_confirm {{skip_confirm}} --dry_run {{dry_run}} --ocp_versions "{{ocp_versions}}"
    else
        just prod-release {{target}} {{app}} {{version}} $rc_arg --skip_confirm {{skip_confirm}} --dry_run {{dry_run}}
    fi

# Query bugs from Jira for a specific application and version
# bundle: "true" (bundle-bugs only), "false" (exclude bundle-bugs, default)
query-bugs app version bundle="false": _check_yq
    #!/usr/bin/env bash
    set -euo pipefail

    # Build bundle filter clause
    if [ "{{bundle}}" = "true" ]; then
        bundle_clause=" and labels = \"bundle-bug\""
    else
        bundle_clause=" and (labels is EMPTY OR labels != \"bundle-bug\")"
    fi

    # Build the JQL query for bugs
    jql_query="project = \"Red Hat Advanced Cluster Management\" and fixVersion = \"{{app}} {{version}}\" and resolution not in (\"Can't Do\", \"Cannot Reproduce\", Duplicate, MirrorOrphan, \"Not a Bug\", Obsolete, Unresolved, \"Won't Do\") and status not in (open, backlog) and statuscategory in (done) and issuetype NOT IN (Vulnerability) and (labels in (doc-required, doc-require, doc-req) OR \"SFDC_Cases_Counter\" > 0)${bundle_clause}"

    # Query Jira for bugs
    jira_output=$(jira issue list -q "$jql_query" --raw 2>&1) || {
        # If query failed, check if it's just "no results" or a real error
        if echo "$jira_output" | grep -q "No result found"; then
            jira_output="[]"
        else
            echo "$jira_output" >&2
            exit 1
        fi
    }

    # Debug: Show bug list with clickable links
    if [[ "{{debug}}" == "true" ]]; then
        echo "[query-bugs] Bugs found:" >&2
        echo "$jira_output" | jq -r '.[] |
            "\u001b]8;;https://redhat.atlassian.net/browse/\(.key)\u001b\\\(.key)\u001b]8;;\u001b\\: \(.fields.summary)"
        ' | sort >&2 || true
        echo "" >&2
    fi

    # Extract and format bug keys
    echo "$jira_output" | jq -r 'map({id: .key, source: "issues.redhat.com"}) | sort_by(.id)' | yq -p=json

# Query CVEs from Jira for a specific application and version
query-cves app version: _check_github_access
    #!/usr/bin/env bash
    set -euo pipefail

    # Create suffix (e.g., "2.13.5" -> "213")
    suffix=$(echo "{{version}}" | cut -d. -f1,2 | tr -d '.')

    # Fetch component registry to temp file
    registry_file=$(mktemp)
    trap "rm -f $registry_file" EXIT
    gh api repos/stolostron/acm-config/contents/product/component-registry.yaml?ref=main --jq '.content' | base64 -d > "$registry_file"

    # Build the JQL query
    jql_query="project = \"Red Hat Advanced Cluster Management\" and issuetype in (Weakness, Vulnerability) and fixVersion = \"{{app}} {{version}}\" and resolution not in (\"Can't Do\", \"Cannot Reproduce\", Duplicate, MirrorOrphan, \"Not a Bug\", Obsolete, Unresolved, \"Won't Do\") and status not in (open, backlog) and \"Embargo Status\" != \"True\""

    # Query Jira for CVEs
    jira_output=$(jira issue list -q "$jql_query" --raw 2>&1) || {
        # If query failed, check if it's just "no results" or a real error
        if echo "$jira_output" | grep -q "No result found"; then
            jira_output="[]"
        else
            echo "$jira_output" >&2
            exit 1
        fi
    }

    # Debug: Show CVE -> Jira issue mapping
    if [[ "{{debug}}" == "true" ]]; then
        echo "[query-cves] CVE to Jira Issue mapping:" >&2
        echo "$jira_output" | jq -r '.[] |
            (.fields.labels[] | select(test("^CVE-[0-9]+-[0-9]+$"))) as $cve |
            (.fields.labels[] | select(startswith("pscomponent:"))) as $ps |
            "\u001b]8;;https://redhat.atlassian.net/browse/\(.key)\u001b\\\(.key)\u001b]8;;\u001b\\: \($cve) (\($ps))"
        ' | sort -k2 >&2 || true
        echo "" >&2
    fi

    # Load component registry
    registry=$(yq -o=json "$registry_file")

    # Output YAML
    output=$(echo "$jira_output" | jq -s --argjson registry "$registry" --arg suffix "$suffix" '
        .[0] as $jira |
        ($registry.components | map(select(.prodseccomponent != null)) | map({(.prodseccomponent): .konflux_component}) | add) as $lookup |
        $jira |
        # Filter to only CVEs with pscomponent labels (catches all formats, including malformed)
        # Exclude Infrastructure Operator component (embargoed assisted-service CVEs)
        map(select(
            (.fields.labels | any(startswith("pscomponent:"))) and
            (.fields.components | all(.name != "Infrastructure Operator[ext]"))
        )) |
        map({
            key: (.fields.labels[] | select(test("^CVE-[0-9]+-[0-9]+$"))),
            prodseccomponent: (.fields.labels[] | select(startswith("pscomponent:")))
        }) |
        map(
            .prodseccomponent as $ps |
            .component = (
                $lookup[$ps] //
                (
                    ("⚠️  Missing mapping for: " + $ps + " (CVE: " + .key + ")") | debug |
                    "FIXME:" + $ps
                )
            ) + "-" + $suffix
        ) |
        map({key, component}) |
        unique
    ' | yq -p=json)

    echo "$output"

    # Exit with error if any FIXME entries exist
    if echo "$output" | grep -q "FIXME:"; then
        exit 1
    fi

# Generate a payload YAML (outputs to stdout)
generate-payload type app version snapshot rc="": (_validate type app rc)
    #!/usr/bin/env bash
    set -euo pipefail

    # Parse version
    read -r major minor patch short_version <<< $(just _parse_version {{version}})

    # Build metadata
    if [ "{{type}}" = "stage" ]; then
        release_name="stage-publish-{{app}}-${short_version}-z${patch}-rc{{rc}}"
        release_plan="stage-publish-{{app}}-${short_version}"
    else
        release_name="prod-publish-{{app}}-${short_version}-z${patch}"
        release_plan="prod-publish-{{app}}-${short_version}"
    fi

    # Y stream releases (X.Y.0) don't include bugs/CVEs
    if [ "$patch" = "0" ]; then
        [[ "{{debug}}" == "true" ]] && echo "[generate-payload] Y stream release detected, skipping bug/CVE queries..." >&2
        release_type="RHEA"
        bug_count=0
        cve_count=0
    else
        [[ "{{debug}}" == "true" ]] && echo "[generate-payload] Querying Jira for bugs and CVEs..." >&2

        # Query bugs and CVEs
        bugs_file=$(mktemp)
        cves_file=$(mktemp)
        trap "rm -f $bugs_file $cves_file" EXIT

        just debug={{debug}} query-bugs {{app}} {{version}} false > "$bugs_file"
        just debug={{debug}} query-cves {{app}} {{version}} > "$cves_file"

        # Determine release type based on CVEs
        cve_count=$(yq 'length' "$cves_file")
        bug_count=$(yq 'length' "$bugs_file")

        if [ "$cve_count" -gt 0 ]; then
            release_type="RHSA"
        elif [ "$bug_count" -gt 0 ]; then
            release_type="RHBA"
        else
            release_type="RHEA"
        fi
    fi

    if [[ "{{debug}}" == "true" ]]; then
        echo "[generate-payload] Generating payload YAML..." >&2
        echo "[generate-payload]   Release type: $release_type" >&2
        echo "[generate-payload]   Bugs: $bug_count" >&2
        echo "[generate-payload]   CVEs: $cve_count" >&2
    fi

    # Build base YAML
    output=$(just debug={{debug}} _build_base {{app}} {{snapshot}} "$release_name" "$release_plan" "$release_type")

    # Add references for ACM RHSA
    if [[ "{{app}}" == "acm" && "$release_type" == "RHSA" ]]; then
        output=$(echo "$output" | yq eval '.spec.data.releaseNotes.references = ["https://access.redhat.com/security/updates/classification/#important"]')
    fi

    # Add bugs if any (only for Z stream releases)
    if [ "$patch" != "0" ] && [ "$bug_count" -gt 0 ]; then
        output=$(echo "$output" | yq eval ".spec.data.releaseNotes.issues.fixed = load(\"$bugs_file\")")
    fi

    # Add CVEs if any (only for Z stream releases)
    if [ "$patch" != "0" ] && [ "$cve_count" -gt 0 ]; then
        output=$(echo "$output" | yq eval ".spec.data.releaseNotes.cves = load(\"$cves_file\")")
    fi

    echo "$output"

# Apply a payload release to the cluster
apply-payload type app version snapshot rc="" skip_confirm="false" dry_run="true": (_validate type app rc) _check_oc_cluster
    #!/usr/bin/env bash
    set -euo pipefail

    # Generate the payload
    payload=$(just debug={{debug}} generate-payload {{type}} {{app}} {{version}} {{snapshot}} {{rc}})

    # Apply using helper
    just _apply "$payload" {{skip_confirm}} {{dry_run}}

# Generate a bundle YAML (outputs to stdout)
generate-bundle type app version snapshot rc="": (_validate type app rc)
    #!/usr/bin/env bash
    set -euo pipefail

    # Parse version
    read -r major minor patch short_version <<< $(just _parse_version {{version}})

    # Build metadata
    if [ "{{type}}" = "stage" ]; then
        release_name="stage-publish-bundle-{{app}}-${short_version}-z${patch}-rc{{rc}}"
        release_plan="stage-publish-bundle-{{app}}-${short_version}"
    else
        release_name="prod-publish-bundle-{{app}}-${short_version}-z${patch}"
        release_plan="prod-publish-bundle-{{app}}-${short_version}"
    fi

    [[ "{{debug}}" == "true" ]] && echo "[generate-bundle] Generating bundle YAML..." >&2

    # Y stream releases (X.Y.0) use RHEA, Z stream releases use RHBA
    if [ "$patch" = "0" ]; then
        release_type="RHEA"
    else
        release_type="RHBA"
    fi

    output=$(just debug={{debug}} _build_base {{app}} {{snapshot}} "$release_name" "$release_plan" "$release_type")

    # Y stream releases (X.Y.0) don't include bugs
    if [ "$patch" != "0" ]; then
        # Query bundle bugs
        bugs_file=$(mktemp)
        trap "rm -f $bugs_file" EXIT

        just debug={{debug}} query-bugs {{app}} {{version}} true > "$bugs_file"

        # Add bugs if any
        bug_count=$(yq 'length' "$bugs_file")
        if [ "$bug_count" -gt 0 ]; then
            output=$(echo "$output" | yq eval ".spec.data.releaseNotes.issues.fixed = load(\"$bugs_file\")")
        fi
    fi

    echo "$output"

# Apply a bundle release to the cluster
apply-bundle type app version snapshot rc="" skip_confirm="false" dry_run="true": (_validate type app rc) _check_oc_cluster
    #!/usr/bin/env bash
    set -euo pipefail

    # Generate the bundle
    bundle=$(just debug={{debug}} generate-bundle {{type}} {{app}} {{version}} {{snapshot}} {{rc}})

    # Apply using helper
    just _apply "$bundle" {{skip_confirm}} {{dry_run}}

# Retrieve FBC catalog images from releases
[arg("rc", long="rc")]
[arg("ocp_versions", long="ocp_versions")]
retrieve-fbc-catalog-images app version rc ocp_versions="": (_validate_app app) _check_oc_cluster
    #!/usr/bin/env bash
    set -euo pipefail

    # Parse version
    read -r major minor patch short_version <<< $(just _parse_version {{version}})

    # Auto-detect OCP versions if not provided
    ocp_versions_resolved="{{ocp_versions}}"
    if [[ -z "{{ocp_versions}}" ]]; then
        ocp_versions_resolved=$(just _get_ocp_versions {{app}} {{version}})
    fi

    # Parse OCP versions
    versions=($(just _parse_ocp_versions "$ocp_versions_resolved"))

    # Retrieve index images for each version
    for ocp_ver in "${versions[@]}"; do
        # Convert version format: 4.12 -> 4-12
        ocp_file_ver=$(echo "$ocp_ver" | tr '.' '-')

        release_name="{{app}}-fbc-ocm-${ocp_file_ver}-stage-{{app}}-${short_version}-z${patch}-rc{{rc}}"
        [[ "{{debug}}" == "true" ]] && echo "📦 OCP $ocp_ver (${release_name})" >&2
        oc get release "$release_name" -n crt-redhat-acm-tenant -o yaml 2>/dev/null | \
            yq '.status.artifacts.components[] | .ocp_version + ": " + .index_image' || \
            { [[ "{{debug}}" == "true" ]] && echo "❌ Release not found or not ready: ${release_name}" >&2; }
    done

# Apply catalog snapshots and releases from directories
apply-catalog type app version rc ocp_versions skip_confirm="false" dry_run="true": (_validate_app app) _check_oc_cluster
    #!/usr/bin/env bash
    set -euo pipefail

    # Parse version
    read -r major minor patch short_version <<< $(just _parse_version {{version}})

    # Build directory paths
    read -r release_dir snapshots_dir releases_dir <<< $(just _catalog_dirs {{type}} {{app}} {{version}} {{rc}})

    # Check directories exist
    if [ ! -d "$snapshots_dir" ] || [ ! -d "$releases_dir" ]; then
        echo "❌ Catalog directories not found" >&2
        echo "   Run 'just generate-catalog {{app}} {{version}} <snapshot> {{rc}} {{ocp_versions}}' first" >&2
        exit 1
    fi

    # Count files
    snapshot_count=$(find "$snapshots_dir" -name "*.yaml" -type f | wc -l)
    release_count=$(find "$releases_dir" -name "*.yaml" -type f | wc -l)

    echo "📦 Applying catalog files..."
    echo "   Snapshots: $snapshot_count files"
    echo "   Releases: $release_count files"
    echo ""

    # Show all files that will be applied
    echo "Files to apply:"
    echo ""
    for file in "$snapshots_dir"/*.yaml; do
        [ -f "$file" ] || continue
        echo "  📄 $(basename "$file")"
    done
    echo ""
    for file in "$releases_dir"/*.yaml; do
        [ -f "$file" ] || continue
        echo "  📄 $(basename "$file")"
    done
    echo ""

    # Confirm before applying
    if [ "{{skip_confirm}}" != "true" ]; then
        if [ "{{dry_run}}" = "true" ]; then
            echo "Press Enter to apply (DRY-RUN), or Ctrl+C to cancel..." >&2
        else
            echo "Press Enter to apply (LIVE), or Ctrl+C to cancel..." >&2
        fi
        read -r
    fi

    # Apply all snapshots, then all releases
    echo "Applying snapshots..."
    if [ "{{dry_run}}" = "true" ]; then
        oc apply --dry-run=server -f "$snapshots_dir"
    else
        oc apply -f "$snapshots_dir"
    fi

    echo ""
    echo "Applying releases..."
    if [ "{{dry_run}}" = "true" ]; then
        oc apply --dry-run=server -f "$releases_dir"
    else
        oc apply -f "$releases_dir"
    fi

    echo ""
    echo "✅ Applied $snapshot_count snapshot(s) and $release_count release(s)"

# checking multiple catalog releases with progress notifications
[arg("rc", long="rc")]
check-catalog-releases type app version rc="" ocp_versions="": _check_oc_cluster
    #!/usr/bin/env bash

    # Parse version
    read -r major minor patch short_version <<< $(just _parse_version {{version}})

    # Auto-detect OCP versions if not provided
    ocp_versions_resolved="{{ocp_versions}}"
    if [[ -z "{{ocp_versions}}" ]]; then
        ocp_versions_resolved=$(just _get_ocp_versions {{app}} {{version}})
    fi

    # Parse OCP versions
    versions=($(just _parse_ocp_versions "$ocp_versions_resolved"))

    rc_suffix=""
    if [ -n "{{rc}}" ]; then
        rc_suffix="-rc{{rc}}"
    fi
    # Build release names
    declare -A RELEASES
    for ocp_ver in "${versions[@]}"; do
        ocp_file_ver=$(echo "$ocp_ver" | tr '.' '-')
        release_name="{{app}}-fbc-ocm-${ocp_file_ver}-{{type}}-{{app}}-${short_version}-z${patch}${rc_suffix}"
        RELEASES[$release_name]="pending"
    done

    TOTAL=${#RELEASES[@]}
    COMPLETED=0
    _N=0
    p() { echo "$@"; ((_N++)); }

    echo "Monitoring ${TOTAL} {{type}} catalog releases for {{app}} {{version}}"
    echo ""

    while true; do
        if [ $_N -gt 0 ]; then
            echo -ne "\033[${_N}A\033[J"
        fi
        _N=0

        for release_name in "${!RELEASES[@]}"; do
            if [[ "${RELEASES[$release_name]}" == "notified" ]]; then
                p "  ✅ $release_name: Complete"
                continue
            fi

            YAML=$(oc get release "$release_name" -oyaml 2>/dev/null)
            STATUS=$(echo "$YAML" | yq '.status.conditions[] | select(.type == "Released") | .status')
            REASON=$(echo "$YAML" | yq '.status.conditions[] | select(.type == "Released") | .reason')

            if [[ "$STATUS" == "True" ]]; then
                RELEASES[$release_name]="notified"
                ((COMPLETED++))

                notify-send "Catalog Release Complete" "$release_name completed ($COMPLETED/$TOTAL)"
                which pw-play >/dev/null 2>&1 && pw-play /usr/share/sounds/freedesktop/stereo/complete.oga --volume 0.5 >/dev/null

                p "  ✅ $release_name: Complete"
            elif [[ "$STATUS" == "False" && "$REASON" == "Failed" ]]; then
                RELEASES[$release_name]="notified"
                ((COMPLETED++))

                notify-send "Catalog Release Failed" "$release_name failed ($COMPLETED/$TOTAL)"
                which pw-play >/dev/null 2>&1 && pw-play /usr/share/sounds/freedesktop/stereo/complete.oga --volume 0.5 >/dev/null

                p "  ❌ $release_name: Failed"
            else
                p "  ⏳ $release_name: Released=$STATUS, Reason=$REASON"
            fi
        done

        p ""
        p "$(date): Progress: $COMPLETED/$TOTAL complete"
        if [[ $COMPLETED -eq $TOTAL ]]; then
            echo ""
            echo "All releases finished!"
            exit 0
        fi

        p ""
        for ((countdown=30; countdown>0; countdown--)); do
            echo -ne "\033[1A\033[K"
            echo "Next check in ${countdown}s..."
            sleep 1
        done
    done

# checking the release and playing a notify-send ping when complete
check-release release:
    #!/usr/bin/env bash

    NAMESPACE="crt-redhat-acm-tenant"
    _N=0
    p() { echo "$@"; ((_N++)); }
    pe() { echo -e "$@"; ((_N++)); }

    echo "Monitoring release {{release}}"

    while true; do
        # Move cursor up _N lines and clear everything below
        if [ $_N -gt 0 ]; then
            echo -ne "\033[${_N}A\033[J"
        fi
        _N=0

        # Fetch release
        YAML=$(oc get release "{{release}}" -n "$NAMESPACE" -oyaml 2>/dev/null)
        if [[ -z "$YAML" ]]; then
            echo "❌ Failed to fetch release - connection issue?"
            exit 1
        fi

        # Extract release status (Released condition has status + reason)
        RELEASE_COND=$(echo "$YAML" | yq '.status.conditions[] | select(.type == "Released") | "\(.status)|\(.reason)|\(.message)"')
        IFS='|' read -r STATUS REASON MESSAGE <<< "$RELEASE_COND"

        # Extract ManagedPipelineProcessed for detailed failure info
        MANAGED_FAILURE=$(echo "$YAML" | yq '.status.conditions[] | select(.type == "ManagedPipelineProcessed" and .status == "False") | .message')

        p "  Status: $STATUS"
        p "  Reason: $REASON"
        if [[ -n "$MANAGED_FAILURE" ]]; then
            p "  Failure: $MANAGED_FAILURE"
        elif [[ -n "$MESSAGE" ]]; then
            p "  Message: $MESSAGE"
        fi
        p ""

        # Extract PipelineRun (format: namespace/name)
        PIPELINE_RUN=$(echo "$YAML" | yq '.status.managedProcessing.pipelineRun')

        if [[ -n "$PIPELINE_RUN" && "$PIPELINE_RUN" != "null" ]]; then
            # Split namespace/name
            PR_NAMESPACE=$(echo "$PIPELINE_RUN" | cut -d'/' -f1)
            PR_NAME=$(echo "$PIPELINE_RUN" | cut -d'/' -f2)

            # Build console URL
            CONSOLE_URL="https://konflux-ui.apps.stone-prd-rh01.pg1f.p1.openshiftapps.com/ns/${PR_NAMESPACE}/pipelinerun/${PR_NAME}"

            pe "PipelineRun: \033]8;;${CONSOLE_URL}\033\\${PR_NAME}\033]8;;\033\\"
            p ""

            # Get PipelineRun to extract all defined tasks
            PR_YAML=$(oc get pipelinerun "$PR_NAME" -n "$PR_NAMESPACE" -o yaml 2>/dev/null)

            if [[ -z "$PR_YAML" ]]; then
                p "⚠️  PipelineRun garbage collected - task details unavailable"
            else
                # Get all task names from pipeline spec (regular + finally tasks)
                ALL_TASKS=$(echo "$PR_YAML" | yq '.status.pipelineSpec.tasks[]?.name, .status.pipelineSpec.finally[]?.name' 2>/dev/null | grep -v '^$')

                # Get existing TaskRuns into associative array
                declare -A TASKRUN_STATUS
                while IFS='|' read -r NAME TR_STATUS TR_REASON; do
                    [[ -z "$NAME" ]] && continue
                    TASK_NAME=$(echo "$NAME" | sed "s/^${PR_NAME}-//")
                    TASKRUN_STATUS["$TASK_NAME"]="$TR_STATUS|$TR_REASON"
                done < <(oc get taskrun -n "$PR_NAMESPACE" -l tekton.dev/pipelineRun="$PR_NAME" -o json 2>/dev/null | \
                    jq -r '.items[] | "\(.metadata.name)|\(.status.conditions[0].status)|\(.status.conditions[0].reason)"')

                TOTAL=0
                SUCCEEDED=0
                FAILED=0
                RUNNING=0
                PENDING=0
                NOT_STARTED=0

                while read -r TASK_NAME; do
                    [[ -z "$TASK_NAME" ]] && continue
                    ((TOTAL++))

                    if [[ -n "${TASKRUN_STATUS[$TASK_NAME]}" ]]; then
                        IFS='|' read -r TR_STATUS TR_REASON <<< "${TASKRUN_STATUS[$TASK_NAME]}"

                        case "$TR_STATUS" in
                            "True")
                                ((SUCCEEDED++))
                                p "  ✅ $TASK_NAME"
                                ;;
                            "False")
                                ((FAILED++))
                                p "  ❌ $TASK_NAME ($TR_REASON)"
                                ;;
                            "Unknown")
                                if [[ "$TR_REASON" == "Running" ]]; then
                                    ((RUNNING++))
                                    p "  ⏳ $TASK_NAME (Running)"
                                else
                                    ((PENDING++))
                                    p "  ⏸  $TASK_NAME (Pending)"
                                fi
                                ;;
                        esac
                    else
                        ((NOT_STARTED++))
                        p "  ⏸  $TASK_NAME (Not started)"
                    fi
                done <<< "$ALL_TASKS"

                p ""
                p "Tasks: $TOTAL total, $SUCCEEDED succeeded, $RUNNING running, $PENDING pending, $NOT_STARTED not started, $FAILED failed"
            fi
        fi

        # Check for completion after showing task details
        if [[ "$REASON" == "Succeeded" ]]; then
            echo ""
            echo "✅ Release completed successfully!"
            notify-send "Release Ready" "{{release}} is released!"
            which pw-play >/dev/null 2>&1 && pw-play /usr/share/sounds/freedesktop/stereo/complete.oga --volume 0.5 >/dev/null
            exit 0
        fi

        if [[ "$REASON" == "Failed" ]]; then
            echo ""
            echo "❌ Release failed!"
            if [[ -n "$MANAGED_FAILURE" ]]; then
                echo "   $MANAGED_FAILURE"
            fi

            FAILED_TASK=""
            if [[ "$MANAGED_FAILURE" =~ task\ ([a-z0-9-]+)\ failed ]]; then
                FAILED_TASK="${BASH_REMATCH[1]}"
                notify-send "Release Failed" "{{release}} failed on task: $FAILED_TASK"
            else
                notify-send "Release Failed" "{{release}} failed!"
            fi
            which pw-play >/dev/null 2>&1 && pw-play /usr/share/sounds/freedesktop/stereo/complete.oga --volume 0.5 >/dev/null
            exit 1
        fi

        p ""
        for ((countdown=30; countdown>0; countdown--)); do
            echo -ne "\033[1A\033[K"
            echo "Next check in ${countdown}s..."
            sleep 1
        done
    done

# checking Konflux commit pipeline runs with notifications
check-commit commit_sha app_name="" namespace="crt-redhat-acm-tenant": _check_oc_cluster
    #!/usr/bin/env bash

    # Build label selectors (build and test use different SHA labels)
    if [[ -n "{{app_name}}" ]]; then
        BUILD_SELECTOR="pipelinesascode.tekton.dev/sha={{commit_sha}},appstudio.openshift.io/application={{app_name}}"
        TEST_SELECTOR="pac.test.appstudio.openshift.io/sha={{commit_sha}},appstudio.openshift.io/application={{app_name}}"
        HEADER="Monitoring commit {{commit_sha}} in {{app_name}}"
    else
        BUILD_SELECTOR="pipelinesascode.tekton.dev/sha={{commit_sha}}"
        TEST_SELECTOR="pac.test.appstudio.openshift.io/sha={{commit_sha}}"
        HEADER="Monitoring commit {{commit_sha}}"
    fi

    MAX_RUNS=0
    _N=0
    p() { echo "$@"; ((_N++)); }

    while true; do
        if [ $_N -gt 0 ]; then
            echo -ne "\033[${_N}A\033[J"
        fi
        _N=0

        p "$HEADER"
        p ""

        # Fetch build pipelines
        BUILD_DATA=$(oc get pipelineruns -n "{{namespace}}" -l "$BUILD_SELECTOR" -o json 2>/dev/null | \
            jq -r '.items[] | "\(.metadata.name)|\(.status.conditions[]? | select(.type == "Succeeded") | .status)|\(.status.conditions[]? | select(.type == "Succeeded") | .reason)"')

        # Fetch test (enterprise-contract) pipelines
        TEST_DATA=$(oc get pipelineruns -n "{{namespace}}" -l "$TEST_SELECTOR" -o json 2>/dev/null | \
            jq -r '.items[] | "\(.metadata.name)|\(.status.conditions[]? | select(.type == "Succeeded") | .status)|\(.status.conditions[]? | select(.type == "Succeeded") | .reason)"')

        # Combine and check if empty
        if [[ -z "$BUILD_DATA" && -z "$TEST_DATA" ]]; then
            if [[ $MAX_RUNS -eq 0 ]]; then
                echo "$(date): No PipelineRuns found"
                exit 1
            else
                echo "$(date): All $MAX_RUNS PipelineRuns completed and garbage collected"
                notify-send "Commit Builds Complete" "All builds finished and cleaned up"
                which pw-play >/dev/null 2>&1 && pw-play /usr/share/sounds/freedesktop/stereo/complete.oga --volume 0.5 >/dev/null
                exit 0
            fi
        fi

        # Build associative arrays: component -> stage/prod -> status
        unset COMPONENTS STAGE_BUILD PROD_BUILD STAGE_EC PROD_EC
        declare -A COMPONENTS
        declare -A STAGE_BUILD
        declare -A PROD_BUILD
        declare -A STAGE_EC
        declare -A PROD_EC

        # Parse builds
        while IFS='|' read -r NAME STATUS REASON; do
            [[ -z "$NAME" ]] && continue

            if [[ "$NAME" =~ ^(.+)-((stage|prod)-)?on-push- ]]; then
                COMPONENT="${BASH_REMATCH[1]}"
                TYPE="${BASH_REMATCH[3]:-stage}"
                COMPONENTS["$COMPONENT"]=1

                case "$STATUS" in
                    "True") ICON="✅" ;;
                    "False") ICON="❌" ;;
                    *) ICON="⏳" ;;
                esac

                if [[ "$TYPE" == "stage" ]]; then
                    STAGE_BUILD["$COMPONENT"]="$ICON"
                else
                    PROD_BUILD["$COMPONENT"]="$ICON"
                fi
            fi
        done <<< "$BUILD_DATA"

        # Parse enterprise-contract tests
        while IFS='|' read -r NAME STATUS REASON; do
            [[ -z "$NAME" ]] && continue

            if [[ "$NAME" =~ ^enterprise-contract-(.+)-((stage|prod)-)? ]]; then
                COMPONENT="${BASH_REMATCH[1]}"
                TYPE="${BASH_REMATCH[3]:-stage}"
                COMPONENTS["$COMPONENT"]=1

                case "$STATUS" in
                    "True") ICON="✅" ;;
                    "False") ICON="❌" ;;
                    *) ICON="⏳" ;;
                esac

                if [[ "$TYPE" == "stage" ]]; then
                    STAGE_EC["$COMPONENT"]="$ICON"
                else
                    PROD_EC["$COMPONENT"]="$ICON"
                fi
            fi
        done <<< "$TEST_DATA"

        # Print table header
        p "$(printf "%-40s  Prod       Stage      Prod       Stage" "Component")"
        p "$(printf "%-40s  Build      Build      EC         EC" "")"
        p "$(printf '%.0s-' {1..85})"

        TOTAL=0
        SUCCESS=0
        FAILED=0
        RUNNING=0

        SORTED_ROWS=""
        for COMPONENT in "${!COMPONENTS[@]}"; do
            PROD_B="${PROD_BUILD[$COMPONENT]:---}"
            STAGE_B="${STAGE_BUILD[$COMPONENT]:---}"
            PROD_E="${PROD_EC[$COMPONENT]:---}"
            STAGE_E="${STAGE_EC[$COMPONENT]:---}"

            ROW=$(printf "%-40s  %s         %s          %s         %s" "$COMPONENT" "$PROD_B" "$STAGE_B" "$PROD_E" "$STAGE_E")
            SORTED_ROWS="${SORTED_ROWS}${ROW}\n"

            for ICON in "$PROD_B" "$STAGE_B" "$PROD_E" "$STAGE_E"; do
                [[ "$ICON" == "--" ]] && continue
                ((TOTAL++))
                case "$ICON" in
                    "✅") ((SUCCESS++)) ;;
                    "❌") ((FAILED++)) ;;
                    "⏳") ((RUNNING++)) ;;
                esac
            done
        done

        while IFS= read -r line; do
            [[ -z "$line" ]] && continue
            p "$line"
        done <<< "$(echo -e "$SORTED_ROWS" | sort)"

        if [[ $TOTAL -gt $MAX_RUNS ]]; then
            MAX_RUNS=$TOTAL
        fi

        p ""
        p "$(date): Total=$TOTAL/$MAX_RUNS Success=$SUCCESS Failed=$FAILED Running=$RUNNING"
        if [[ $RUNNING -eq 0 && $TOTAL -gt 0 ]]; then
            echo ""
            echo "✅ All builds complete!"
            notify-send "Commit Builds Complete" "All $TOTAL builds finished (Success: $SUCCESS, Failed: $FAILED)"
            which pw-play >/dev/null 2>&1 && pw-play /usr/share/sounds/freedesktop/stereo/complete.oga --volume 0.5 >/dev/null
            exit 0
        fi

        p ""
        for ((countdown=30; countdown>0; countdown--)); do
            echo -ne "\033[1A\033[K"
            echo "Next check in ${countdown}s..."
            sleep 1
        done
    done

# checking GitHub action and PR merge status with notifications
check-pr target pr_number:
    #!/usr/bin/env bash

    case "{{target}}" in
        bundle-acm)
            REPO="stolostron/acm-operator-bundle"
            WORKFLOW="Gen Bundle Contents When Triggered"
            ;;
        bundle-mce)
            REPO="stolostron/mce-operator-bundle"
            WORKFLOW="Gen Bundle Contents When Triggered"
            ;;
        catalog)
            REPO="stolostron/acm-mce-operator-catalogs"
            WORKFLOW="Gen Catalog Content When Requested"
            ;;
        *)
            echo "Unknown target: {{target}}"
            echo "Valid targets: bundle-acm, bundle-mce, catalog"
            exit 1
            ;;
    esac

    # Get PR branch name
    PR_DATA=$(gh pr view "{{pr_number}}" --repo "$REPO" --json headRefName,title 2>/dev/null)
    BRANCH=$(echo "$PR_DATA" | jq -r '.headRefName')
    PR_TITLE=$(echo "$PR_DATA" | jq -r '.title')

    if [[ -z "$BRANCH" ]]; then
        echo "Failed to get PR #{{pr_number}} info"
        exit 1
    fi

    echo "Monitoring GitHub action and PR..."
    echo "  Repository: $REPO"
    echo "  PR: #{{pr_number}} - $PR_TITLE"
    echo "  Branch: $BRANCH"
    echo "  Workflow: $WORKFLOW"
    echo ""

    # Wait for workflow to complete
    while true; do
        RUN_DATA=$(gh run list --repo "$REPO" --branch "$BRANCH" --workflow "$WORKFLOW" --json conclusion,status,workflowName,databaseId --limit 5 2>/dev/null)
        RUN_INFO=$(echo "$RUN_DATA" | jq -r '.[0] | {status: .status, conclusion: .conclusion, id: .databaseId} | @json' 2>/dev/null)

        if [[ -z "$RUN_INFO" || "$RUN_INFO" == "null" ]]; then
            echo "$(date): No workflow run found for branch $BRANCH"
            sleep 30
            continue
        fi

        STATUS=$(echo "$RUN_INFO" | jq -r '.status')
        CONCLUSION=$(echo "$RUN_INFO" | jq -r '.conclusion')
        RUN_ID=$(echo "$RUN_INFO" | jq -r '.id')

        echo "$(date): Workflow run $RUN_ID - Status=$STATUS, Conclusion=$CONCLUSION"

        if [[ "$STATUS" == "completed" ]]; then
            if [[ "$CONCLUSION" == "success" ]]; then
                break
            else
                notify-send "GitHub Action Failed" "PR #{{pr_number}} workflow failed: $CONCLUSION"
                which pw-play >/dev/null 2>&1 && pw-play /usr/share/sounds/freedesktop/stereo/complete.oga --volume 0.5 >/dev/null
                exit 1
            fi
        fi

        sleep 30
    done

    echo ""
    echo "Workflow succeeded! Monitoring PR merge..."
    echo ""

    # Wait for PR merge
    while true; do
        PR_STATE=$(gh pr view "{{pr_number}}" --repo "$REPO" --json state,mergedAt,mergeCommit 2>/dev/null)

        if [[ -z "$PR_STATE" ]]; then
            echo "$(date): Failed to get PR status"
            sleep 30
            continue
        fi

        STATE=$(echo "$PR_STATE" | jq -r '.state')
        MERGED_AT=$(echo "$PR_STATE" | jq -r '.mergedAt')
        MERGE_SHA=$(echo "$PR_STATE" | jq -r '.mergeCommit.oid // empty')

        echo "$(date): PR #{{pr_number}} - State=$STATE"

        if [[ "$STATE" == "MERGED" ]]; then
            echo ""
            echo "✅ PR #{{pr_number}} merged!"
            if [[ -n "$MERGE_SHA" ]]; then
                echo "   Merge commit: $MERGE_SHA"
            fi
            notify-send "PR Merged" "PR #{{pr_number}} has been merged!"
            which pw-play >/dev/null 2>&1 && pw-play /usr/share/sounds/freedesktop/stereo/complete.oga --volume 0.5 >/dev/null
            exit 0
        fi

        if [[ "$STATE" == "CLOSED" ]]; then
            notify-send "PR Closed" "PR #{{pr_number}} was closed without merging"
            which pw-play >/dev/null 2>&1 && pw-play /usr/share/sounds/freedesktop/stereo/complete.oga --volume 0.5 >/dev/null
            exit 1
        fi

        sleep 30
    done

# Setup catalog release structure: create directories, split snapshot, and generate Release YAMLs
generate-catalog app version snapshot rc ocp_versions: (_validate_app app) _check_oc_cluster _setup_python_venv
    #!/usr/bin/env bash
    set -euo pipefail

    # Parse version
    read -r major minor patch short_version <<< $(just _parse_version {{version}})

    # Build directory paths
    read -r release_dir snapshots_dir releases_dir <<< $(just _catalog_dirs stage {{app}} {{version}} {{rc}})

    echo "📁 Setting up catalog directories..."
    echo "   Base: ${release_dir}"

    # Create directories
    mkdir -p "$snapshots_dir"
    mkdir -p "$releases_dir"
    echo "   ✓ Created: snapshots/"
    echo "   ✓ Created: releases/"
    echo ""

    # Fetch snapshot from cluster
    echo "📥 Fetching snapshot from cluster..."
    snapshot_file="${release_dir}/snapshot-{{snapshot}}.yaml"
    oc get snapshot {{snapshot}} -n crt-redhat-acm-tenant -o yaml > "$snapshot_file" || {
        echo "❌ Failed to fetch snapshot {{snapshot}} from cluster" >&2
        exit 1
    }
    echo "   ✓ Saved: $(basename "$snapshot_file")"
    echo ""

    # Split the snapshot using split_snapshot.py
    echo "🔨 Splitting snapshot into individual components..."
    split_script="{{justfile_directory()}}/lib/split_snapshot.py"
    python_bin="{{justfile_directory()}}/.venv/bin/python"

    if [ ! -f "$split_script" ]; then
        echo "❌ Error: split_snapshot.py not found at $split_script" >&2
        exit 1
    fi

    # Parse and convert OCP versions for Python script (space-separated -> comma-separated)
    versions_space=$(just _parse_ocp_versions {{ocp_versions}})
    versions_comma=$(echo "$versions_space" | tr ' ' ',')

    "$python_bin" "$split_script" "$snapshot_file" "$snapshots_dir" "$versions_comma"
    echo ""

    # Generate Release YAML files for each snapshot
    echo "📝 Generating Release YAML files..."
    namespace="crt-redhat-acm-tenant"
    release_plan="{{app}}-release-plan-stage"
    author=$(just _get_author)

    # Build version suffix: -acm-212-z42-rc1
    version_suffix="{{app}}-${short_version}-z${patch}-rc{{rc}}"

    count=0
    for snapshot_file in "$snapshots_dir"/snapshot-*.yaml; do
        [ -f "$snapshot_file" ] || continue

        # Extract base component name from snapshot filename
        base_component=$(basename "$snapshot_file" .yaml | sed 's/^snapshot-//')

        # Skip if already has version suffix (from previous run)
        if [[ "$base_component" == *"-${version_suffix}" ]]; then
            continue
        fi

        # Append version suffix
        snapshot_name="${base_component}-${version_suffix}"
        release_name="${base_component}-${version_suffix}"

        # Update the snapshot name in the snapshot file
        yq eval -i ".metadata.name = \"${snapshot_name}\"" "$snapshot_file"

        # Rename snapshot file to include version suffix
        versioned_snapshot_file="${snapshots_dir}/snapshot-${snapshot_name}.yaml"
        mv "$snapshot_file" "$versioned_snapshot_file"

        # Generate release YAML using yq to avoid heredoc issues
        release_file="${releases_dir}/${release_name}.yaml"

        yq eval ".metadata.name = \"${release_name}\" |
            .metadata.namespace = \"${namespace}\" |
            .metadata.labels[\"release.appstudio.openshift.io/author\"] = \"${author}\" |
            .spec.snapshot = \"${snapshot_name}\" |
            .spec.releasePlan = \"${release_plan}\" |
            .spec.data.releaseNotes.type = \"RHEA\"" \
            "{{justfile_directory()}}/templates/release.yaml" > "$release_file"

        echo "   ✓ Created: $(basename "$release_file")"
        count=$((count + 1))
    done

    echo ""
    echo "✅ Catalog setup complete!"
    echo "   Directory: ${release_dir}"
    echo "   Snapshots: ${count} files in snapshots/"
    echo "   Releases: ${count} files in releases/"

# Get advisory from release
get-advisory release_name: _check_oc_cluster
    oc get release {{release_name}} -n crt-redhat-acm-tenant -o yaml | yq -r .status.artifacts.advisory

# Remove cloned repos
cleanup:
    #!/usr/bin/env bash
    set -euo pipefail

    dirs=("acm-release-management" "bundle-repos")

    for repo_dir in "${dirs[@]}"; do
        if [ -d "$repo_dir" ]; then
            rm -rf "$repo_dir"
            echo "✅ Removed $repo_dir"
        else
            echo "ℹ️  $repo_dir does not exist"
        fi
    done

# Create a GitLab merge request for the release management branch
create-mr app version:
    #!/usr/bin/env bash
    set -euo pipefail

    repo_dir="acm-release-management"
    branch_name="release-{{app}}-{{version}}"
    gitlab_host="gitlab.cee.redhat.com"
    upstream="acm/acm-release-management"
    app_upper=$(echo "{{app}}" | tr '[:lower:]' '[:upper:]')

    if [ ! -d "$repo_dir" ]; then
        echo "❌ Release management repo not found" >&2
        echo "   Run a release workflow first to populate it" >&2
        exit 1
    fi

    cd "$repo_dir"

    # Switch to the expected branch if not already on it
    current_branch=$(git branch --show-current)
    if [ "$current_branch" != "$branch_name" ]; then
        echo "⚠️  On branch '$current_branch', switching to '$branch_name'..." >&2
        git fetch origin
        if git show-ref --verify --quiet refs/heads/"$branch_name"; then
            git checkout "$branch_name"
            git pull origin "$branch_name" --ff-only 2>/dev/null || true
        elif git show-ref --verify --quiet refs/remotes/origin/"$branch_name"; then
            git checkout -b "$branch_name" origin/"$branch_name"
        else
            echo "❌ Branch '$branch_name' not found locally or on remote" >&2
            exit 1
        fi
    fi

    # Check there are commits ahead of main
    commits_ahead=$(git rev-list --count origin/main..HEAD 2>/dev/null || echo "0")
    if [ "$commits_ahead" = "0" ]; then
        echo "❌ No commits ahead of main — nothing to merge" >&2
        exit 1
    fi

    echo "📬 Creating merge request on GitLab..."
    echo "   Branch: $branch_name ($commits_ahead commits ahead of main)"
    echo "   Target: main"
    echo ""

    # Show commit log
    echo "Commits:"
    git log --oneline origin/main..HEAD
    echo ""

    # Empty commit needed for git push -o to trigger MR creation
    git commit --allow-empty -m "Trigger MR creation"

    # Push and create MR via git push options
    mr_title="${app_upper} {{version}} release files"

    push_output=$(git push origin HEAD \
        -o merge_request.create \
        -o merge_request.target=main \
        -o "merge_request.title=${mr_title}" 2>&1)

    echo "$push_output"

    # Extract and display MR URL
    mr_url=$(echo "$push_output" | grep -oE 'https://[^ ]+merge_requests/[0-9]+' | head -1)
    if [ -n "$mr_url" ]; then
        echo ""
        echo "✅ Merge request created: $mr_url"
    fi

# Get snapshot name from merged PR number
get-snapshot-from-pr app pr_number: (_validate_app app) _check_github_access _check_oc_cluster
    #!/usr/bin/env bash
    set -euo pipefail

    repo="stolostron/{{app}}-operator-bundle"
    namespace="crt-redhat-acm-tenant"

    # Get merge commit SHA from PR
    echo "🔍 Fetching commit SHA from PR #{{pr_number}} ($repo)..." >&2
    commit_sha=$(gh pr view {{pr_number}} --repo "$repo" --json mergeCommit --jq '.mergeCommit.oid')

    if [ -z "$commit_sha" ] || [ "$commit_sha" = "null" ]; then
        echo "❌ Failed to get merge commit from PR #{{pr_number}}" >&2
        echo "   PR may not be merged yet" >&2
        exit 1
    fi

    echo "  Commit SHA: $commit_sha" >&2
    echo "" >&2

    # Find snapshot with that SHA
    echo "🔍 Finding snapshot with commit SHA..." >&2
    snapshot_name=$(oc get snapshots -n "$namespace" \
        -l "pac.test.appstudio.openshift.io/sha=$commit_sha" \
        -o jsonpath='{.items[0].metadata.name}')

    if [ -z "$snapshot_name" ]; then
        echo "❌ No snapshot found for commit $commit_sha" >&2
        exit 1
    fi

    echo "  Snapshot: $snapshot_name" >&2
    echo "" >&2

    # Output snapshot name to stdout
    echo "$snapshot_name"

# Verify catalog snapshot contains the expected app version for relevant OCP versions
verify-catalog-snapshot type app version snapshot: (_validate_app app) _check_oc_cluster _check_github_access
    #!/usr/bin/env bash
    set -euo pipefail

    namespace="crt-redhat-acm-tenant"

    if [ "{{app}}" = "acm" ]; then
        package="advanced-cluster-management"
    else
        package="multicluster-engine"
    fi

    read -r major minor patch short_version <<< $(just _parse_version {{version}})
    expected="v${major}.${minor}.${patch}"

    # Get relevant OCP versions for this app+version
    ocp_csv=$(just _get_ocp_versions {{app}} {{version}})
    IFS=',' read -ra ocp_versions <<< "$ocp_csv"

    echo "🔍 Verifying catalog snapshot {{snapshot}}"
    echo "   Package: $package"
    echo "   Expected version: $expected"
    echo "   OCP versions: ${ocp_versions[*]}"
    echo ""

    # Build lookup of component name -> image from snapshot
    declare -A comp_images
    while IFS='|' read -r name image; do
        [[ -z "$name" ]] && continue
        comp_images["$name"]="$image"
    done <<< "$(oc get snapshot "{{snapshot}}" -n "$namespace" -o json | \
        jq -r '.spec.components[] | "\(.name)|\(.containerImage)"')"

    PASS=0
    FAIL=0
    TOTAL=0

    for ocp_ver in "${ocp_versions[@]}"; do
        ocp_dash=$(echo "$ocp_ver" | tr '.' '-')
        comp_name="{{app}}-fbc-ocm-${ocp_dash}-{{type}}"
        image="${comp_images[$comp_name]:-}"

        if [[ -z "$image" ]]; then
            echo "  ⚠️  OCP $ocp_ver: component $comp_name not in snapshot"
            FAIL=$((FAIL + 1))
            TOTAL=$((TOTAL + 1))
            continue
        fi

        TOTAL=$((TOTAL + 1))

        highest=$(opm render "$image" -oyaml 2>/dev/null | \
            yq ".name | select(test(\"^${package}\\.v\"))" | \
            grep -v '^---$' | \
            awk -F. '{minor=$2"."$3; patch=$4+0; if (!(minor in max) || patch > max[minor]) max[minor]=patch} END {for (m in max) print m"."max[m]}' | \
            sort -V)

        if echo "$highest" | grep -q "^${expected}$"; then
            echo "  ✅ OCP $ocp_ver: $expected found"
            PASS=$((PASS + 1))
        else
            echo "  ❌ OCP $ocp_ver: $expected NOT found"
            echo "     Versions present: $(echo "$highest" | tr '\n' ' ')"
            FAIL=$((FAIL + 1))
        fi
    done

    echo ""
    echo "Results: $PASS/$TOTAL passed"

    if [ $FAIL -gt 0 ]; then
        exit 1
    fi

# Find the catalog snapshot where required OCP components share the given git revision
get-catalog-snapshot type app version commit_sha: (_validate_app app) _check_oc_cluster
    #!/usr/bin/env bash
    set -euo pipefail

    application="{{app}}-operator-catalog-{{type}}"
    namespace="crt-redhat-acm-tenant"

    # Get required OCP versions and build required component names
    ocp_csv=$(just _get_ocp_versions {{app}} {{version}})
    IFS=',' read -ra ocp_versions <<< "$ocp_csv"

    required_components=()
    for ocp_ver in "${ocp_versions[@]}"; do
        ocp_dash=$(echo "$ocp_ver" | tr '.' '-')
        required_components+=("{{app}}-fbc-ocm-${ocp_dash}-{{type}}")
    done

    # Build jq filter array
    required_json=$(printf '%s\n' "${required_components[@]}" | jq -R . | jq -s .)

    echo "🔍 Finding catalog snapshot for $application with commit {{commit_sha}}..." >&2
    echo "   Required components: ${required_components[*]}" >&2

    snapshot_name=$(oc get snapshots -n "$namespace" \
        -l "appstudio.openshift.io/application=$application" \
        -o json | jq -r --arg app "$application" --arg sha "{{commit_sha}}" --argjson required "$required_json" '
        [.items[] |
        select(.metadata.name | startswith($app + "-")) |
        # Check only required components have the expected revision
        select(
            [.spec.components[] |
            select(.name as $n | $required | index($n)) |
            .source.git.revision // "none"] as $revs |
            ($revs | length) == ($required | length) and
            ($revs | unique) == [$sha]
        )] |
        sort_by(.metadata.creationTimestamp) | last | .metadata.name // empty
    ')

    if [ -z "$snapshot_name" ]; then
        echo "❌ No converged snapshot found" >&2
        echo "   Required components must have git revision {{commit_sha}}" >&2
        exit 1
    fi

    component_count=$(oc get snapshot "$snapshot_name" -n "$namespace" -o json | jq '.spec.components | length')
    matched_count=${#required_components[@]}
    echo "  Snapshot: $snapshot_name ($component_count total components, $matched_count required)" >&2
    echo "" >&2

    echo "$snapshot_name"

# Clone release management repo and create a branch
clone-release-mgmt branch_name:
    #!/usr/bin/env bash
    set -euo pipefail

    repo_dir="acm-release-management"
    upstream="acm/acm-release-management"
    gitlab_host="gitlab.cee.redhat.com"

    # Clone if not exists (use method determined by access check)
    if [ ! -d "$repo_dir" ]; then
        clone_method=$(just _check_gitlab_access)
        if [ "$clone_method" = "ssh" ]; then
            git clone "git@${gitlab_host}:${upstream}.git"
        else
            git clone "https://${gitlab_host}/${upstream}.git"
        fi
    fi

    cd "$repo_dir"

    # Fetch latest
    git fetch origin

    # Create branch from main if it doesn't exist, otherwise switch to it
    if git show-ref --verify --quiet refs/heads/{{branch_name}}; then
        git checkout {{branch_name}}
        git pull origin {{branch_name}} --ff-only 2>/dev/null || true
        echo "✅ Switched to existing branch {{branch_name}}"
    elif git show-ref --verify --quiet refs/remotes/origin/{{branch_name}}; then
        git checkout -b {{branch_name}} origin/{{branch_name}}
        echo "✅ Checked out remote branch {{branch_name}}"
    else
        git checkout -b {{branch_name}} origin/main
        git push -u origin {{branch_name}}
        echo "✅ Branch {{branch_name}} created from origin/main"
    fi

# Stage release: generate YAML, save to disk, and apply to cluster
[arg("skip_confirm", long="skip_confirm")]
[arg("rc", long="rc")]
[arg("dry_run", long="dry_run")]
[arg("ocp_versions", long="ocp_versions")]
stage-release target app version snapshot rc="" skip_confirm="false" dry_run="true" ocp_versions="": (_validate_app app) (_validate_rc rc) _check_yq _check_oc_cluster
    #!/usr/bin/env bash
    set -euo pipefail

    # Validate target
    if [[ "{{target}}" != "payload" && "{{target}}" != "bundle" && "{{target}}" != "catalog" ]]; then
        echo "Error: target must be 'payload', 'bundle', or 'catalog'" >&2
        exit 1
    fi

    # Parse version
    read -r major minor patch short_version <<< $(just _parse_version {{version}})

    # Auto-detect OCP versions for catalog if not provided
    ocp_versions_resolved="{{ocp_versions}}"
    if [[ "{{target}}" == "catalog" && -z "{{ocp_versions}}" ]]; then
        echo "🔍 Auto-detecting OCP versions from catalog config..." >&2
        ocp_versions_resolved=$(just _get_ocp_versions {{app}} {{version}})
        echo "  ✓ Detected OCP versions: ${ocp_versions_resolved}" >&2
    fi

    # Ensure workspace exists and correct branch checked out
    workspace_dir=$(just _ensure_release_mgmt_workspace stage {{app}} {{version}})

    # Build directory path (stage always goes in rc subdirectory)
    app_upper=$(echo "{{app}}" | tr '[:lower:]' '[:upper:]')
    release_dir="$workspace_dir/${app_upper}/${app_upper}-{{version}}/rc{{rc}}"
    suffix="stage-z${patch}-rc{{rc}}"

    # Branch based on target type
    if [ "{{target}}" = "catalog" ]; then
        # Catalog workflow: setup multi-file structure and apply
        echo "📦 Setting up catalog release..." >&2
        just debug={{debug}} generate-catalog {{app}} {{version}} {{snapshot}} {{rc}} "${ocp_versions_resolved}"

        echo "" >&2
        echo "📋 Catalog files generated in: $workspace_dir" >&2
        echo "" >&2

        # Apply catalogs (confirmation happens inside apply-catalog)
        just debug={{debug}} apply-catalog stage {{app}} {{version}} {{rc}} "${ocp_versions_resolved}" {{skip_confirm}} {{dry_run}}
    else
        # Payload/Bundle workflow: single YAML generation and apply
        # Create directory if it doesn't exist
        mkdir -p "$release_dir"
        echo "📁 Saving release files to: $release_dir" >&2

        # Fetch and save snapshot from cluster first (fail if not found)
        echo "  Fetching snapshot from cluster..." >&2
        snapshot_file="${release_dir}/snapshot-{{app}}-${short_version}-{{target}}-${suffix}.yaml"
        oc get snapshot {{snapshot}} -n crt-redhat-acm-tenant -o yaml > "$snapshot_file" || {
            echo "❌ Failed to fetch snapshot {{snapshot}} from cluster" >&2
            exit 1
        }
        echo "  ✓ Saved: $(basename "$snapshot_file")" >&2

        # Generate the YAML (hardcoded to stage)
        echo "  Generating {{target}}..." >&2
        target_yaml=$(just debug={{debug}} generate-{{target}} stage {{app}} {{version}} {{snapshot}} {{rc}})

        # Save to disk
        target_file="${release_dir}/{{app}}-${short_version}-{{target}}-${suffix}.yaml"
        echo "$target_yaml" > "$target_file"
        echo "" >&2
        echo "  ✓ Saved: $(basename "$target_file")" >&2
        echo "✅ Release {{target}} saved successfully!" >&2
        echo "   Directory: $release_dir" >&2

        # Apply to cluster
        echo "" >&2
        just _apply "$target_yaml" {{skip_confirm}} {{dry_run}}
    fi

    # Push release files incrementally
    just _push_release_mgmt_files "stage {{target}} {{app}} {{version}} rc{{rc}}"

# Promote stage to prod: copy stage file, update for prod, and apply to cluster
[arg("rc", long="rc")]
[arg("skip_confirm", long="skip_confirm")]
[arg("dry_run", long="dry_run")]
prod-release target app version rc="" skip_confirm="false" dry_run="true": (_validate_app app) (_validate_rc rc) _check_yq _check_oc_cluster
    #!/usr/bin/env bash
    set -euo pipefail

    # Validate target
    if [[ "{{target}}" != "payload" && "{{target}}" != "bundle" && "{{target}}" != "catalog" ]]; then
        echo "Error: target must be 'payload', 'bundle', or 'catalog'" >&2
        exit 1
    fi

    # Parse version
    read -r major minor patch short_version <<< $(just _parse_version {{version}})

    # Ensure workspace exists and correct branch checked out
    workspace_dir=$(just _ensure_release_mgmt_workspace prod {{app}} {{version}})

    # Build paths
    app_upper=$(echo "{{app}}" | tr '[:lower:]' '[:upper:]')
    base_dir="$workspace_dir/${app_upper}/${app_upper}-{{version}}"

    if [ "{{target}}" = "catalog" ]; then
        # Catalog: promote multiple files
        read -r stage_catalogs_dir stage_snapshots_dir stage_releases_dir <<< $(just _catalog_dirs stage {{app}} {{version}} {{rc}})
        read -r prod_catalogs_dir prod_snapshots_dir prod_releases_dir <<< $(just _catalog_dirs prod {{app}} {{version}} {{rc}})

        # Check stage catalog directories exist
        if [ ! -d "$stage_snapshots_dir" ] || [ ! -d "$stage_releases_dir" ]; then
            echo "❌ Stage catalog directories not found: $stage_catalogs_dir" >&2
            echo "   Run 'just release catalog stage {{app}} {{version}} <snapshot> --rc {{rc}}' first" >&2
            exit 1
        fi

        # Create prod directories
        mkdir -p "$prod_snapshots_dir"
        mkdir -p "$prod_releases_dir"

        echo "📦 Promoting stage catalogs to prod..." >&2

        # Process snapshots
        snapshot_count=0
        for stage_file in "$stage_snapshots_dir"/snapshot-*.yaml; do
            [ -f "$stage_file" ] || continue
            filename=$(basename "$stage_file")
            # Remove RC suffix and replace stage with prod
            prod_filename=$(echo "$filename" | sed "s/-rc{{rc}}//" | sed "s/stage/prod/")
            prod_file="$prod_snapshots_dir/$prod_filename"

            # Transform YAML (replace stage with prod and remove RC suffix from metadata.name)
            yq eval '.metadata.name |= sub("stage", "prod") | .metadata.name |= sub("-rc{{rc}}", "") | .spec.application |= sub("stage", "prod")' \
                "$stage_file" > "$prod_file"

            echo "  ✓ Snapshot: $prod_filename" >&2
            snapshot_count=$((snapshot_count + 1))
        done

        # Process releases
        release_count=0
        for stage_file in "$stage_releases_dir"/*.yaml; do
            [ -f "$stage_file" ] || continue
            filename=$(basename "$stage_file")
            # Remove RC suffix and replace stage with prod
            prod_filename=$(echo "$filename" | sed "s/-rc{{rc}}//" | sed "s/stage/prod/")
            prod_file="$prod_releases_dir/$prod_filename"

            # Transform YAML (replace stage with prod and remove RC suffix from metadata.name and spec.snapshot)
            yq eval '.metadata.name |= sub("stage", "prod") | .metadata.name |= sub("-rc{{rc}}", "") | .spec.snapshot |= sub("stage", "prod") | .spec.snapshot |= sub("-rc{{rc}}", "") | .spec.releasePlan |= sub("stage", "prod")' \
                "$stage_file" > "$prod_file"

            echo "  ✓ Release: $prod_filename" >&2
            release_count=$((release_count + 1))
        done

        echo "" >&2
        echo "✅ Created $snapshot_count snapshot(s) and $release_count release(s)" >&2
        echo "" >&2

        # Apply catalog files
        just debug={{debug}} apply-catalog prod {{app}} {{version}} {{rc}} "" {{skip_confirm}} {{dry_run}}

    else
        # Payload/Bundle: promote single file
        stage_file="${base_dir}/rc{{rc}}/{{app}}-${short_version}-{{target}}-stage-z${patch}-rc{{rc}}.yaml"
        prod_file="${base_dir}/{{app}}-${short_version}-{{target}}-prod-z${patch}.yaml"

        stage_snapshot_file="${base_dir}/rc{{rc}}/snapshot-{{app}}-${short_version}-{{target}}-stage-z${patch}-rc{{rc}}.yaml"
        prod_snapshot_file="${base_dir}/snapshot-{{app}}-${short_version}-{{target}}-prod-z${patch}.yaml"

        # Check stage files exist
        if [ ! -f "$stage_file" ]; then
            echo "❌ Stage {{target}} file not found: $stage_file" >&2
            echo "   Run 'just release {{target}} stage {{app}} {{version}} <snapshot> --rc {{rc}}' first" >&2
            exit 1
        fi

        if [ ! -f "$stage_snapshot_file" ]; then
            echo "❌ Stage snapshot file not found: $stage_snapshot_file" >&2
            echo "   Run 'just release {{target}} stage {{app}} {{version}} <snapshot> --rc {{rc}}' first" >&2
            exit 1
        fi

        echo "📦 Promoting stage {{target}} to prod..." >&2

        # Copy snapshot file
        cp "$stage_snapshot_file" "$prod_snapshot_file"
        echo "  ✓ Snapshot: $(basename "$prod_snapshot_file")" >&2

        # Copy and transform release file
        echo "  Source: $(basename "$stage_file")" >&2
        echo "  Dest: $(basename "$prod_file")" >&2

        yq eval '.metadata.name |= sub("stage", "prod") | .spec.releasePlan |= sub("stage", "prod")' \
            "$stage_file" > "$prod_file"

        echo "  ✓ Release: $(basename "$prod_file")" >&2
        echo "" >&2

        # Read and apply to cluster
        prod_yaml=$(cat "$prod_file")
        just _apply "$prod_yaml" {{skip_confirm}} {{dry_run}}
    fi

    # Push release files incrementally
    just _push_release_mgmt_files "prod {{target}} {{app}} {{version}} (from stage rc{{rc}})"

# Generate snapshot updates: wrapper for bundle or catalog snapshot updates
[arg("rc", long="rc")]
[arg("skip_confirm", long="skip_confirm")]
[arg("dry_run", long="dry_run")]
generate-snapshot target type app version rc="" skip_confirm="false" dry_run="true": _check_yq
    #!/usr/bin/env bash
    set -euo pipefail

    # Validate target
    if [[ "{{target}}" != "bundle" && "{{target}}" != "catalog" ]]; then
        echo "Error: target must be 'bundle' or 'catalog'" >&2
        exit 1
    fi

    # Build rc argument if provided
    rc_arg=""
    if [ -n "{{rc}}" ]; then
        rc_arg="--rc {{rc}}"
    fi

    # Route to appropriate recipe
    if [ "{{target}}" = "bundle" ]; then
        just update-bundle-snapshot {{type}} {{app}} {{version}} $rc_arg --skip_confirm {{skip_confirm}} --dry_run {{dry_run}}
    else
        just update-catalog-request {{type}} {{app}} {{version}} $rc_arg --skip_confirm {{skip_confirm}} --dry_run {{dry_run}}
    fi

# Update operator bundle repository with latest snapshot
[arg("rc", long="rc")]
[arg("skip_confirm", long="skip_confirm")]
[arg("dry_run", long="dry_run")]
update-bundle-snapshot type app version rc="" skip_confirm="false" dry_run="true": (_validate type app rc) _check_github_access
    #!/usr/bin/env bash
    set -euo pipefail

    # Parse version
    read -r major minor patch short_version <<< $(just _parse_version {{version}})

    # Ensure workspace exists and correct branch checked out
    workspace_dir=$(just _ensure_release_mgmt_workspace {{type}} {{app}} {{version}})

    app_upper=$(echo "{{app}}" | tr '[:lower:]' '[:upper:]')
    release_dir="$workspace_dir/${app_upper}/${app_upper}-{{version}}"

    if [ "{{type}}" = "stage" ]; then
        release_dir="${release_dir}/rc{{rc}}"
        suffix="stage-z${patch}-rc{{rc}}"
    else
        suffix="prod-z${patch}"
    fi

    snapshot_file="${release_dir}/snapshot-{{app}}-${short_version}-payload-${suffix}.yaml"

    # Verify snapshot file exists
    if [ ! -f "$snapshot_file" ]; then
        echo "❌ Snapshot file not found: $snapshot_file" >&2
        echo "   Run 'just release payload {{type}} {{app}} {{version}} <snapshot> --rc {{rc}}' first" >&2
        exit 1
    fi

    # Convert to absolute path before changing directories
    snapshot_file=$(realpath "$snapshot_file")

    echo "📦 Updating operator bundle repository..." >&2
    echo "  Snapshot file: $(basename "$snapshot_file")" >&2

    # Determine bundle repo and branch
    if [ "{{app}}" = "acm" ]; then
        bundle_repo="acm-operator-bundle"
        release_branch="release-${major}.${minor}"
    else
        bundle_repo="mce-operator-bundle"
        release_branch="backplane-${major}.${minor}"
    fi

    echo "  Repository: stolostron/${bundle_repo}" >&2
    echo "  Branch: ${release_branch}" >&2

    # Clone or update bundle repo
    bundle_dir="{{justfile_directory()}}/bundle-repos/${bundle_repo}"
    mkdir -p "{{justfile_directory()}}/bundle-repos"

    if [ ! -d "$bundle_dir" ]; then
        echo "  Cloning ${bundle_repo}..." >&2
        gh repo clone "stolostron/${bundle_repo}" "$bundle_dir"
    fi

    cd "$bundle_dir"

    # Fetch and checkout release branch
    echo "  Fetching latest from origin..." >&2
    git fetch origin

    if ! git rev-parse --verify "origin/${release_branch}" &>/dev/null; then
        echo "❌ Branch ${release_branch} does not exist in remote" >&2
        echo "   Available branches:" >&2
        git branch -r | grep -v HEAD | sed 's/origin\///' >&2
        exit 1
    fi

    # Checkout and update release branch
    if git show-ref --verify --quiet "refs/heads/${release_branch}"; then
        git checkout "$release_branch"
        echo "  Pulling latest changes..." >&2
        git pull origin "$release_branch"
    else
        git checkout -b "$release_branch" "origin/${release_branch}"
    fi

    # Compare snapshots
    echo "🔍 Comparing snapshots..." >&2

    if [ ! -f "latest-snapshot.yaml" ]; then
        echo "  ⚠ latest-snapshot.yaml does not exist, will create new file" >&2
        action="create"
        current_generation=0
    elif diff -q "$snapshot_file" latest-snapshot.yaml &>/dev/null; then
        echo "  ✓ Snapshots are identical, will increment generation" >&2
        action="increment"
        current_generation=$(yq '.metadata.generation' latest-snapshot.yaml)
    else
        echo "  ⚠ Snapshots differ, will replace file" >&2
        action="replace"
        current_generation=$(yq '.metadata.generation' latest-snapshot.yaml 2>/dev/null || echo "0")
    fi

    # Update file based on action
    if [ "$action" = "increment" ]; then
        # Files are identical - only increment generation
        new_generation=$((current_generation + 1))
        yq eval -i '.metadata.generation = '"${new_generation}" latest-snapshot.yaml
        commit_msg="Increment snapshot generation to ${new_generation}"$'\n\n'"For {{app}} {{version}} ${suffix}"
    else
        # Files differ - replace completely (keep generation from source snapshot)
        cp "$snapshot_file" latest-snapshot.yaml
        new_generation=$(yq '.metadata.generation' latest-snapshot.yaml)
        if [ "$action" = "replace" ]; then
            commit_msg="Update snapshot for {{app}} {{version}} ${suffix}"$'\n\n'"Replaced latest-snapshot yaml with new snapshot."$'\n'"Generation: ${new_generation}"
        else
            commit_msg="Create snapshot for {{app}} {{version}} ${suffix}"$'\n\n'"Initial creation of latest-snapshot yaml."$'\n'"Generation: ${new_generation}"
        fi
    fi


    # Commit and create PR
    if [ "{{dry_run}}" = "true" ]; then
        echo "🏃 DRY-RUN: Would create PR with:" >&2
        echo "  Action: ${action}" >&2
        if [ "$action" = "increment" ]; then
            echo "  Generation: ${current_generation} → ${new_generation}" >&2
        else
            echo "  Generation: ${new_generation}" >&2
        fi
        echo "  Branch: snapshot-update-{{app}}-${short_version}-z${patch}$([ "{{type}}" = "stage" ] && echo "-rc{{rc}}" || echo "")" >&2
        echo "  Title: Update snapshot for {{app}} {{version}}" >&2
        echo "" >&2
        echo "Run with dry_run=false to create actual PR" >&2
    else
        # Create feature branch
        feature_branch="snapshot-update-{{app}}-${short_version}-z${patch}"
        if [ "{{type}}" = "stage" ]; then
            feature_branch="${feature_branch}-rc{{rc}}"
        fi

        # Check if branch exists and handle
        if git show-ref --verify --quiet "refs/heads/${feature_branch}"; then
            echo "⚠️  Branch ${feature_branch} already exists" >&2
            if [ "{{skip_confirm}}" != "true" ]; then
                echo "Press Enter to delete and recreate, or Ctrl+C to cancel..." >&2
                read -r
            fi
            git checkout "$release_branch"
            git branch -D "$feature_branch"
        fi

        echo "📝 Creating commit..." >&2
        git checkout -b "$feature_branch"
        git add latest-snapshot.yaml

        # Get git author info and build full commit message
        author=$(just _get_author)
        full_commit_msg="${commit_msg}"
        full_commit_msg="${full_commit_msg}"$'\n\n'"Signed-off-by: $(git config user.name) $(git config user.email)"
        full_commit_msg="${full_commit_msg}"$'\n'"Co-Authored-By: Claude Sonnet 4 point 5 noreply at anthropic.com"

        git commit -m "${full_commit_msg}"

        echo "🚀 Pushing to origin..." >&2
        git push -u origin "$feature_branch"

        echo "📬 Creating pull request..." >&2
        snapshot_basename=$(basename "$snapshot_file")
        if [ "$action" = "increment" ]; then
            pr_body="Summary: Update snapshot for {{app}} {{version}} (${action}, generation ${current_generation} to ${new_generation})"
        else
            pr_body="Summary: Update snapshot for {{app}} {{version}} (${action}, generation ${new_generation})"
        fi

        pr_url=$(gh pr create \
            --base "$release_branch" \
            --title "Update snapshot for {{app}} {{version}}" \
            --body "${pr_body}")

        echo "" >&2
        echo "✅ Pull request created: $pr_url" >&2
    fi

# Update catalog request with bundle container image
[arg("rc", long="rc")]
[arg("skip_confirm", long="skip_confirm")]
[arg("dry_run", long="dry_run")]
update-catalog-request type app version rc="" skip_confirm="false" dry_run="true": (_validate type app rc) _check_github_access
    #!/usr/bin/env bash
    set -euo pipefail

    # Parse version
    read -r major minor patch short_version <<< $(just _parse_version {{version}})

    # Ensure workspace exists and correct branch checked out
    workspace_dir=$(just _ensure_release_mgmt_workspace {{type}} {{app}} {{version}})

    app_upper=$(echo "{{app}}" | tr '[:lower:]' '[:upper:]')
    release_dir="$workspace_dir/${app_upper}/${app_upper}-{{version}}"

    if [ "{{type}}" = "stage" ]; then
        release_dir="${release_dir}/rc{{rc}}"
        suffix="stage-z${patch}-rc{{rc}}"
    else
        suffix="prod-z${patch}"
    fi

    bundle_snapshot_file="${release_dir}/snapshot-{{app}}-${short_version}-bundle-${suffix}.yaml"

    # Verify bundle snapshot file exists
    if [ ! -f "$bundle_snapshot_file" ]; then
        echo "❌ Bundle snapshot file not found: $bundle_snapshot_file" >&2
        echo "   Run 'just release bundle {{type}} {{app}} {{version}} <snapshot> --rc {{rc}}' first" >&2
        exit 1
    fi

    # Extract container image from bundle snapshot
    container_image=$(yq '.spec.components[].containerImage' "$bundle_snapshot_file")

    if [ -z "$container_image" ]; then
        echo "❌ No container image found in bundle snapshot" >&2
        exit 1
    fi

    echo "📦 Updating catalog request..." >&2
    echo "  Bundle snapshot: $(basename "$bundle_snapshot_file")" >&2
    echo "  Container image: ${container_image}" >&2

    # Determine catalog repo branch
    if [ "{{app}}" = "acm" ]; then
        catalog_branch="acm-redhat-operators"
    else
        catalog_branch="mce-redhat-operators"
    fi

    echo "  Repository: stolostron/acm-mce-operator-catalogs" >&2
    echo "  Branch: ${catalog_branch}" >&2

    # Clone or update catalog repo
    catalog_dir="{{justfile_directory()}}/bundle-repos/acm-mce-operator-catalogs"
    mkdir -p "{{justfile_directory()}}/bundle-repos"

    if [ ! -d "$catalog_dir" ]; then
        echo "  Cloning acm-mce-operator-catalogs..." >&2
        gh repo clone "stolostron/acm-mce-operator-catalogs" "$catalog_dir"
    fi

    cd "$catalog_dir"

    # Fetch and checkout catalog branch
    echo "  Fetching latest from origin..." >&2
    git fetch origin

    if ! git rev-parse --verify "origin/${catalog_branch}" &>/dev/null; then
        echo "❌ Branch ${catalog_branch} does not exist in remote" >&2
        echo "   Available branches:" >&2
        git branch -r | grep -v HEAD | sed 's/origin\///' >&2
        exit 1
    fi

    # Checkout and update catalog branch
    if git show-ref --verify --quiet "refs/heads/${catalog_branch}"; then
        git checkout "$catalog_branch"
        echo "  Pulling latest changes..." >&2
        git pull origin "$catalog_branch"
    else
        git checkout -b "$catalog_branch" "origin/${catalog_branch}"
    fi

    # Update catalog-request.yaml
    echo "🔍 Updating catalog-request.yaml..." >&2

    # Set container image in additional-bundles[0]
    yq eval -i ".additional-bundles[0] = \"${container_image}\"" catalog-request.yaml

    # Update request-time to current timestamp
    current_time=$(date)
    yq eval -i ".request-time = \"${current_time}\"" catalog-request.yaml

    commit_msg="Update catalog request for {{app}} {{version}}"$'\n\n'"Bundle: ${container_image}"

    # Commit and create PR
    if [ "{{dry_run}}" = "true" ]; then
        echo "" >&2
        echo "🏃 DRY-RUN: Would create PR with:" >&2
        echo "  Bundle: ${container_image}" >&2
        echo "  Request time: ${current_time}" >&2
        echo "  Branch: catalog-update-{{app}}-${short_version}-z${patch}$([ "{{type}}" = "stage" ] && echo "-rc{{rc}}" || echo "")" >&2
        echo "  Title: Update catalog request for {{app}} {{version}}" >&2
        echo "" >&2
        echo "Run with \`--dry_run false\` to create actual PR" >&2
    else
        # Create feature branch
        feature_branch="catalog-update-{{app}}-${short_version}-z${patch}"
        if [ "{{type}}" = "stage" ]; then
            feature_branch="${feature_branch}-rc{{rc}}"
        fi

        # Check if branch exists and handle
        if git show-ref --verify --quiet "refs/heads/${feature_branch}"; then
            echo "⚠️  Branch ${feature_branch} already exists" >&2
            if [ "{{skip_confirm}}" != "true" ]; then
                echo "Press Enter to delete and recreate, or Ctrl+C to cancel..." >&2
                read -r
            fi
            git checkout "$catalog_branch"
            git branch -D "$feature_branch"
        fi

        echo "📝 Creating commit..." >&2
        git checkout -b "$feature_branch"
        git add catalog-request.yaml

        # Get git author info and build full commit message
        author=$(just _get_author)
        full_commit_msg="${commit_msg}"
        full_commit_msg="${full_commit_msg}"$'\n\n'"Signed-off-by: $(git config user.name) $(git config user.email)"
        full_commit_msg="${full_commit_msg}"$'\n'"Co-Authored-By: Claude Sonnet 4 point 5 noreply at anthropic.com"

        git commit -m "${full_commit_msg}"

        echo "🚀 Pushing to origin..." >&2
        git push -u origin "$feature_branch"

        echo "📬 Creating pull request..." >&2
        pr_body="Summary: Update catalog request for {{app}} {{version}} with bundle ${container_image}"

        pr_url=$(gh pr create \
            --base "$catalog_branch" \
            --title "Update catalog request for {{app}} {{version}}" \
            --body "${pr_body}")

        echo "" >&2
        echo "✅ Pull request created: $pr_url" >&2
    fi
