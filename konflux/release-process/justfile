import 'utils.just'

# Debug flag (set to "true" to enable debug output)
debug := "false"

# Workspace directory for saving release files (can be overridden)
workspace := "."

# Query bugs from Jira for a specific application and version
# bundle: "true" (bundle-bugs only), "false" (exclude bundle-bugs, default)
query-bugs app version bundle="false":
    #!/usr/bin/env bash
    set -euo pipefail

    # Build bundle filter clause
    if [ "{{bundle}}" = "true" ]; then
        bundle_clause=" and labels = \"bundle-bug\""
    else
        bundle_clause=" and (labels is EMPTY OR labels != \"bundle-bug\")"
    fi

    # Build the JQL query for bugs
    jql_query="project = \"Red Hat Advanced Cluster Management\" and fixVersion = \"{{app}} {{version}}\" and resolution not in (\"Can't Do\", \"Cannot Reproduce\", Duplicate, MirrorOrphan, \"Not a Bug\", Obsolete, Unresolved, \"Won't Do\") and status not in (open, backlog) and issuetype NOT IN (Weakness, Vulnerability) and (labels in (doc-required, doc-require, doc-req) OR \"SFDC_Cases_Counter\" > 0)${bundle_clause}"

    # Query Jira for bugs
    jira_output=$(jira issue list -q "$jql_query" --raw 2>&1) || {
        # If query failed, check if it's just "no results" or a real error
        if echo "$jira_output" | grep -q "No result found"; then
            jira_output="[]"
        else
            echo "$jira_output" >&2
            exit 1
        fi
    }

    # Debug: Show bug list with clickable links
    if [[ "{{debug}}" == "true" ]]; then
        echo "[query-bugs] Bugs found:" >&2
        echo "$jira_output" | jq -r '.[] |
            "\u001b]8;;https://redhat.atlassian.net/browse/\(.key)\u001b\\\(.key)\u001b]8;;\u001b\\: \(.fields.summary)"
        ' | sort >&2 || true
        echo "" >&2
    fi

    # Extract and format bug keys
    echo "$jira_output" | jq -r 'map({id: .key, source: "issues.redhat.com"}) | sort_by(.id)' | yq -p=json

# Query CVEs from Jira for a specific application and version
query-cves app version:
    #!/usr/bin/env bash
    set -euo pipefail

    # Create suffix (e.g., "2.13.5" -> "213")
    suffix=$(echo "{{version}}" | cut -d. -f1,2 | tr -d '.')

    # Fetch component registry to temp file
    registry_file=$(mktemp)
    trap "rm -f $registry_file" EXIT
    gh api repos/stolostron/acm-config/contents/product/component-registry.yaml?ref=main --jq '.content' | base64 -d > "$registry_file"

    # Build the JQL query
    jql_query="project = \"Red Hat Advanced Cluster Management\" and issuetype in (Weakness, Vulnerability) and fixVersion = \"{{app}} {{version}}\" and resolution not in (\"Can't Do\", \"Cannot Reproduce\", Duplicate, MirrorOrphan, \"Not a Bug\", Obsolete, Unresolved, \"Won't Do\") and status not in (open, backlog)"

    # Query Jira for CVEs
    jira_output=$(jira issue list -q "$jql_query" --raw 2>&1) || {
        # If query failed, check if it's just "no results" or a real error
        if echo "$jira_output" | grep -q "No result found"; then
            jira_output="[]"
        else
            echo "$jira_output" >&2
            exit 1
        fi
    }

    # Debug: Show CVE -> Jira issue mapping
    if [[ "{{debug}}" == "true" ]]; then
        echo "[query-cves] CVE to Jira Issue mapping:" >&2
        echo "$jira_output" | jq -r '.[] |
            (.fields.labels[] | select(test("^CVE-[0-9]+-[0-9]+$"))) as $cve |
            (.fields.labels[] | select(startswith("pscomponent:"))) as $ps |
            "\u001b]8;;https://redhat.atlassian.net/browse/\(.key)\u001b\\\(.key)\u001b]8;;\u001b\\: \($cve) (\($ps))"
        ' | sort -k2 >&2 || true
        echo "" >&2
    fi

    # Load component registry
    registry=$(yq -o=json "$registry_file")

    # Output YAML
    output=$(echo "$jira_output" | jq -s --argjson registry "$registry" --arg suffix "$suffix" '
        .[0] as $jira |
        ($registry.components | map(select(.prodseccomponent != null)) | map({(.prodseccomponent): .konflux_component}) | add) as $lookup |
        $jira |
        # Filter to only CVEs with pscomponent labels matching rhacm2* or multicluster-engine*
        map(select(
            .fields.labels | any(
                startswith("pscomponent:rhacm2") or
                startswith("pscomponent:multicluster-engine")
            )
        )) |
        map({
            key: (.fields.labels[] | select(test("^CVE-[0-9]+-[0-9]+$"))),
            prodseccomponent: (.fields.labels[] | select(startswith("pscomponent:")))
        }) |
        map(
            .prodseccomponent as $ps |
            .component = (
                $lookup[$ps] //
                (
                    ("⚠️  Missing mapping for: " + $ps + " (CVE: " + .key + ")") | debug |
                    "FIXME:" + $ps
                )
            ) + "-" + $suffix
        ) |
        map({key, component}) |
        unique
    ' | yq -p=json)

    echo "$output"

    # Exit with error if any FIXME entries exist
    if echo "$output" | grep -q "FIXME:"; then
        exit 1
    fi

# Generate a payload YAML (outputs to stdout)
generate-payload type app version snapshot rc="": (_validate type app rc)
    #!/usr/bin/env bash
    set -euo pipefail

    # Parse version
    read -r major minor patch short_version <<< $(just _parse_version {{version}})

    # Build metadata
    if [ "{{type}}" = "stage" ]; then
        release_name="stage-publish-{{app}}-${short_version}-z${patch}-rc{{rc}}"
        release_plan="stage-publish-{{app}}-${short_version}"
    else
        release_name="prod-publish-{{app}}-${short_version}-z${patch}"
        release_plan="prod-publish-{{app}}-${short_version}"
    fi

    # Y stream releases (X.Y.0) don't include bugs/CVEs
    if [ "$patch" = "0" ]; then
        [[ "{{debug}}" == "true" ]] && echo "[generate-payload] Y stream release detected, skipping bug/CVE queries..." >&2
        release_type="RHEA"
        bug_count=0
        cve_count=0
    else
        [[ "{{debug}}" == "true" ]] && echo "[generate-payload] Querying Jira for bugs and CVEs..." >&2

        # Query bugs and CVEs
        bugs_file=$(mktemp)
        cves_file=$(mktemp)
        trap "rm -f $bugs_file $cves_file" EXIT

        just debug={{debug}} query-bugs {{app}} {{version}} false > "$bugs_file"
        just debug={{debug}} query-cves {{app}} {{version}} > "$cves_file"

        # Determine release type based on CVEs
        cve_count=$(yq 'length' "$cves_file")
        bug_count=$(yq 'length' "$bugs_file")

        if [ "$cve_count" -gt 0 ]; then
            release_type="RHSA"
        elif [ "$bug_count" -gt 0 ]; then
            release_type="RHBA"
        else
            release_type="RHEA"
        fi
    fi

    if [[ "{{debug}}" == "true" ]]; then
        echo "[generate-payload] Generating payload YAML..." >&2
        echo "[generate-payload]   Release type: $release_type" >&2
        echo "[generate-payload]   Bugs: $bug_count" >&2
        echo "[generate-payload]   CVEs: $cve_count" >&2
    fi

    # Build base YAML
    output=$(just debug={{debug}} _build_base {{app}} {{snapshot}} "$release_name" "$release_plan" "$release_type")

    # Add references for ACM RHSA
    if [[ "{{app}}" == "acm" && "$release_type" == "RHSA" ]]; then
        output=$(echo "$output" | yq eval '.spec.data.releaseNotes.references = ["https://access.redhat.com/security/updates/classification/#important"]')
    fi

    # Add bugs if any (only for Z stream releases)
    if [ "$patch" != "0" ] && [ "$bug_count" -gt 0 ]; then
        output=$(echo "$output" | yq eval ".spec.data.releaseNotes.issues.fixed = load(\"$bugs_file\")")
    fi

    # Add CVEs if any (only for Z stream releases)
    if [ "$patch" != "0" ] && [ "$cve_count" -gt 0 ]; then
        output=$(echo "$output" | yq eval ".spec.data.releaseNotes.cves = load(\"$cves_file\")")
    fi

    echo "$output"

# Apply a payload release to the cluster
apply-payload type app version snapshot rc="" skip_confirm="false" dry_run="true": (_validate type app rc) _check_oc_cluster
    #!/usr/bin/env bash
    set -euo pipefail

    # Generate the payload
    payload=$(just debug={{debug}} generate-payload {{type}} {{app}} {{version}} {{snapshot}} {{rc}})

    # Apply using helper
    just _apply "$payload" {{skip_confirm}} {{dry_run}}

# Generate a bundle YAML (outputs to stdout)
generate-bundle type app version snapshot rc="": (_validate type app rc)
    #!/usr/bin/env bash
    set -euo pipefail

    # Parse version
    read -r major minor patch short_version <<< $(just _parse_version {{version}})

    # Build metadata
    if [ "{{type}}" = "stage" ]; then
        release_name="stage-publish-bundle-{{app}}-${short_version}-z${patch}-rc{{rc}}"
        release_plan="stage-publish-bundle-{{app}}-${short_version}"
    else
        release_name="prod-publish-bundle-{{app}}-${short_version}-z${patch}"
        release_plan="prod-publish-bundle-{{app}}-${short_version}"
    fi

    [[ "{{debug}}" == "true" ]] && echo "[generate-bundle] Generating bundle YAML..." >&2

    # Build base YAML (bundle is always RHBA)
    output=$(just debug={{debug}} _build_base {{app}} {{snapshot}} "$release_name" "$release_plan" "RHBA")

    # Y stream releases (X.Y.0) don't include bugs
    if [ "$patch" != "0" ]; then
        # Query bundle bugs
        bugs_file=$(mktemp)
        trap "rm -f $bugs_file" EXIT

        just debug={{debug}} query-bugs {{app}} {{version}} true > "$bugs_file"

        # Add bugs if any
        bug_count=$(yq 'length' "$bugs_file")
        if [ "$bug_count" -gt 0 ]; then
            output=$(echo "$output" | yq eval ".spec.data.releaseNotes.issues.fixed = load(\"$bugs_file\")")
        fi
    fi

    echo "$output"

# Apply a bundle release to the cluster
apply-bundle type app version snapshot rc="" skip_confirm="false" dry_run="true": (_validate type app rc) _check_oc_cluster
    #!/usr/bin/env bash
    set -euo pipefail

    # Generate the bundle
    bundle=$(just debug={{debug}} generate-bundle {{type}} {{app}} {{version}} {{snapshot}} {{rc}})

    # Apply using helper
    just _apply "$bundle" {{skip_confirm}} {{dry_run}}

# Retrieve FBC catalog images from releases
retrieve-fbc-catalog-images app version rc ocp_versions: (_validate_app app) _check_oc_cluster
    #!/usr/bin/env bash
    set -euo pipefail

    # Parse version
    read -r major minor patch short_version <<< $(just _parse_version {{version}})

    # Parse OCP versions
    versions=($(just _parse_ocp_versions {{ocp_versions}}))

    # Retrieve index images for each version
    for ocp_ver in "${versions[@]}"; do
        # Convert version format: 4.12 -> 4-12
        ocp_file_ver=$(echo "$ocp_ver" | tr '.' '-')

        release_name="{{app}}-fbc-ocm-${ocp_file_ver}-stage-${short_version}-z${patch}-rc{{rc}}"

        [[ "{{debug}}" == "true" ]] && echo "📦 OCP $ocp_ver (${release_name})" >&2
        oc get release "$release_name" -n crt-redhat-acm-tenant -o yaml 2>/dev/null | \
            yq '.status.artifacts.components[] | .ocp_version + ": " + .index_image' || \
            { [[ "{{debug}}" == "true" ]] && echo "❌ Release not found or not ready: ${release_name}" >&2; }
    done

# Apply a list of catalog snapshots and releases
apply-catalog app version rc ocp_versions skip_confirm="false" dry_run="true": (_validate_app app) _check_oc_cluster
    #!/usr/bin/env bash
    set -euo pipefail

    # Parse version
    read -r major minor patch short_version <<< $(just _parse_version {{version}})

    # Build directory paths
    read -r release_dir snapshots_dir releases_dir <<< $(just _catalog_dirs {{app}} {{version}} {{rc}})

    # Parse OCP versions
    versions=($(just _parse_ocp_versions {{ocp_versions}}))

    # Apply snapshots and releases for each version
    for ocp_ver in "${versions[@]}"; do
        # Convert version format: 4.12 -> 4-12
        ocp_file_ver=$(echo "$ocp_ver" | tr '.' '-')

        snapshot_file="${snapshots_dir}/snapshot-{{app}}-fbc-ocm-${ocp_file_ver}-stage-${short_version}-z${patch}-rc{{rc}}.yaml"
        release_file="${releases_dir}/{{app}}-fbc-ocm-${ocp_file_ver}-stage-${short_version}-z${patch}-rc{{rc}}.yaml"

        # Check files exist
        if [[ ! -f "$snapshot_file" ]]; then
            echo "❌ Snapshot not found: $snapshot_file" >&2
            exit 1
        fi
        if [[ ! -f "$release_file" ]]; then
            echo "❌ Release not found: $release_file" >&2
            exit 1
        fi

        echo "📦 OCP $ocp_ver"
        echo ""
        echo "  → Snapshot: $(basename "$snapshot_file")"
        echo "---"
        cat "$snapshot_file"
        echo "---"
        echo ""
        echo "  → Release: $(basename "$release_file")"
        echo "---"
        cat "$release_file"
        echo "---"
        echo ""

        # Confirm before applying
        if [ "{{skip_confirm}}" != "true" ]; then
            if [ "{{dry_run}}" = "true" ]; then
                echo "Press Enter to continue (DRY-RUN), or Ctrl+C to cancel..." >&2
            else
                echo "Press Enter to continue (LIVE), or Ctrl+C to cancel..." >&2
            fi
            read -r
        fi

        # Apply both files
        echo "Applying..."
        if [ "{{dry_run}}" = "true" ]; then
            oc apply --dry-run=server -f "$snapshot_file"
            oc apply --dry-run=server -f "$release_file"
        else
            oc apply -f "$snapshot_file"
            oc apply -f "$release_file"
        fi
        echo ""
    done

    echo "✅ Applied ${#versions[@]} catalog(s)"

    

# Setup catalog release structure: create directories, split snapshot, and generate Release YAMLs
generate-catalog app version snapshot rc: (_validate_app app) _check_oc_cluster _setup_python_venv
    #!/usr/bin/env bash
    set -euo pipefail

    # Parse version
    read -r major minor patch short_version <<< $(just _parse_version {{version}})

    # Build directory paths
    read -r release_dir snapshots_dir releases_dir <<< $(just _catalog_dirs {{app}} {{version}} {{rc}})

    echo "📁 Setting up catalog directories..."
    echo "   Base: ${release_dir}"

    # Create directories
    mkdir -p "$snapshots_dir"
    mkdir -p "$releases_dir"
    echo "   ✓ Created: snapshots/"
    echo "   ✓ Created: releases/"
    echo ""

    # Fetch snapshot from cluster
    echo "📥 Fetching snapshot from cluster..."
    snapshot_file="${release_dir}/snapshot-{{snapshot}}.yaml"
    oc get snapshot {{snapshot}} -n crt-redhat-acm-tenant -o yaml > "$snapshot_file" || {
        echo "❌ Failed to fetch snapshot {{snapshot}} from cluster" >&2
        exit 1
    }
    echo "   ✓ Saved: $(basename "$snapshot_file")"
    echo ""

    # Split the snapshot using split_snapshot.py
    echo "🔨 Splitting snapshot into individual components..."
    split_script="{{justfile_directory()}}/lib/split_snapshot.py"
    python_bin="{{justfile_directory()}}/.venv/bin/python"

    if [ ! -f "$split_script" ]; then
        echo "❌ Error: split_snapshot.py not found at $split_script" >&2
        exit 1
    fi

    "$python_bin" "$split_script" "$snapshot_file" "$snapshots_dir"
    echo ""

    # Generate Release YAML files for each snapshot
    echo "📝 Generating Release YAML files..."
    namespace="crt-redhat-acm-tenant"
    release_plan="{{app}}-release-plan-stage"
    author=$(just _get_author)

    # Build version suffix
    version_suffix="${short_version}-z${patch}-rc{{rc}}"

    count=0
    for snapshot_file in "$snapshots_dir"/snapshot-*.yaml; do
        [ -f "$snapshot_file" ] || continue

        # Extract component name from snapshot filename
        component_name=$(basename "$snapshot_file" .yaml | sed 's/^snapshot-//')

        # Add version suffix to create unique names
        snapshot_name="${component_name}-${version_suffix}"
        release_name="${component_name}-${version_suffix}"

        # Update the snapshot name in the snapshot file
        yq eval -i ".metadata.name = \"${snapshot_name}\"" "$snapshot_file"

        # Rename snapshot file to include version
        versioned_snapshot_file="${snapshots_dir}/snapshot-${snapshot_name}.yaml"
        mv "$snapshot_file" "$versioned_snapshot_file"

        # Generate release YAML using yq to avoid heredoc issues
        release_file="${releases_dir}/${release_name}.yaml"

        yq eval ".metadata.name = \"${release_name}\" |
            .metadata.namespace = \"${namespace}\" |
            .metadata.labels[\"release.appstudio.openshift.io/author\"] = \"${author}\" |
            .spec.snapshot = \"${snapshot_name}\" |
            .spec.releasePlan = \"${release_plan}\" |
            .spec.data.releaseNotes.type = \"RHEA\"" \
            "{{justfile_directory()}}/templates/release.yaml" > "$release_file"

        echo "   ✓ Created: $(basename "$release_file")"
        count=$((count + 1))
    done

    echo ""
    echo "✅ Catalog setup complete!"
    echo "   Directory: ${release_dir}"
    echo "   Snapshots: ${count} files in snapshots/"
    echo "   Releases: ${count} files in releases/"

# Remove cloned release management repo
cleanup:
    #!/usr/bin/env bash
    set -euo pipefail

    repo_dir="acm-release-management"

    if [ -d "$repo_dir" ]; then
        rm -rf "$repo_dir"
        echo "✅ Removed $repo_dir"
    else
        echo "ℹ️  $repo_dir does not exist"
    fi

# Clone release management repo and create a branch
clone-release-mgmt branch_name cert_file="": _check_gitlab_access
    #!/usr/bin/env bash
    set -euo pipefail

    repo_dir="acm-release-management"
    upstream="acm/acm-release-management"
    gitlab_host="gitlab.cee.redhat.com"

    # Set SSL cert file if provided
    if [ -n "{{cert_file}}" ]; then
        export SSL_CERT_FILE="{{cert_file}}"
    fi

    # Clone if not exists
    if [ ! -d "$repo_dir" ]; then
        git clone git@$gitlab_host:$upstream.git
    fi

    cd "$repo_dir"

    # Fetch latest
    git fetch origin

    # Create branch from main if it doesn't exist, otherwise switch to it
    if git show-ref --verify --quiet refs/heads/{{branch_name}}; then
        git checkout {{branch_name}}
        echo "✅ Switched to existing branch {{branch_name}}"
    else
        git checkout -b {{branch_name}} origin/main
        echo "✅ Branch {{branch_name}} created from origin/main"
    fi

# Release: generate YAML, save to disk, and apply to cluster
[arg("skip_confirm", long="false")]
[arg("cert_file", long="cert_file")]
[arg("rc", long="rc")]
[arg("dry_run", long="dry_run")]
[arg("ocp_versions", long="ocp_versions")]
release target type app version snapshot rc="" skip_confirm="false" dry_run="true" cert_file="" ocp_versions="": (_validate type app rc) _check_oc_cluster
    #!/usr/bin/env bash
    set -euo pipefail

    # Validate target
    if [[ "{{target}}" != "payload" && "{{target}}" != "bundle" && "{{target}}" != "catalog" ]]; then
        echo "Error: target must be 'payload', 'bundle', or 'catalog'" >&2
        exit 1
    fi

    # Validate catalog-specific requirements
    if [[ "{{target}}" == "catalog" && -z "{{ocp_versions}}" ]]; then
        echo "Error: ocp_versions parameter is required for catalog releases" >&2
        exit 1
    fi

    # Parse version
    read -r major minor patch short_version <<< $(just _parse_version {{version}})

    # If workspace is default, clone the release management repo
    workspace_dir="{{workspace}}"
    if [ "$workspace_dir" = "." ]; then
        # Clone release management repo and create branch
        branch_name="{{type}}-release-{{app}}-${short_version}-z${patch}"
        if [ "{{type}}" = "stage" ]; then
            branch_name="${branch_name}-rc{{rc}}"
        fi

        just clone-release-mgmt "$branch_name" "{{cert_file}}"
        workspace_dir="acm-release-management"
    fi

    # Build directory path
    app_upper=$(echo "{{app}}" | tr '[:lower:]' '[:upper:]')
    release_dir="$workspace_dir/${app_upper}/${app_upper}-{{version}}"

    if [ "{{type}}" = "stage" ]; then
        release_dir="${release_dir}/rc{{rc}}"
        suffix="stage-z${patch}-rc{{rc}}"
    else
        suffix="prod-z${patch}"
    fi

    # Branch based on target type
    if [ "{{target}}" = "catalog" ]; then
        # Catalog workflow: setup multi-file structure and apply
        echo "📦 Setting up catalog release..." >&2
        just debug={{debug}} generate-catalog {{app}} {{version}} {{snapshot}} {{rc}}

        echo "" >&2
        echo "📋 Catalog files generated in: $workspace_dir" >&2
        echo "" >&2

        # Apply catalogs (confirmation happens inside apply-catalog)
        just debug={{debug}} apply-catalog {{app}} {{version}} {{rc}} {{ocp_versions}} {{skip_confirm}} {{dry_run}}
    else
        # Payload/Bundle workflow: single YAML generation and apply
        # Create directory if it doesn't exist
        mkdir -p "$release_dir"
        echo "📁 Saving release files to: $release_dir" >&2

        # Fetch and save snapshot from cluster first (fail if not found)
        echo "  Fetching snapshot from cluster..." >&2
        snapshot_file="${release_dir}/snapshot-{{app}}-${short_version}-{{target}}-${suffix}.yaml"
        oc get snapshot {{snapshot}} -n crt-redhat-acm-tenant -o yaml > "$snapshot_file" || {
            echo "❌ Failed to fetch snapshot {{snapshot}} from cluster" >&2
            exit 1
        }
        echo "  ✓ Saved: $(basename "$snapshot_file")" >&2

        # Generate the YAML
        echo "  Generating {{target}}..." >&2
        target_yaml=$(just debug={{debug}} generate-{{target}} {{type}} {{app}} {{version}} {{snapshot}} {{rc}})

        # Save to disk
        target_file="${release_dir}/{{app}}-${short_version}-{{target}}-${suffix}.yaml"
        echo "$target_yaml" > "$target_file"
        echo "" >&2
        echo "  ✓ Saved: $(basename "$target_file")" >&2
        echo "✅ Release {{target}} saved successfully!" >&2
        echo "   Directory: $release_dir" >&2

        # Apply to cluster
        echo "" >&2
        just _apply "$target_yaml" {{skip_confirm}} {{dry_run}}
    fi
